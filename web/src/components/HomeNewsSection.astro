---
import { blogPosts, blogSectionMeta } from '../data/site';

const featured = blogPosts[0];
const gridPosts = blogPosts.slice(1);
const { allPostsHref } = blogSectionMeta;
const sliderSets = 3;
const sliderPosts = Array.from({ length: sliderSets }, () => blogPosts).flat();
---

<section class="home-news py-8 md:py-24 bg-white border-b border-border-subtle" id="tin-tuc">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <header
      class="home-news-header flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 md:gap-4 mb-6 md:mb-12"
    >
      <div class="max-w-2xl">
        <span
          class="inline-block px-3 py-1 bg-accent-teal-light text-accent-teal rounded-full text-xs font-bold uppercase tracking-wider mb-3 md:mb-4"
          >Blog</span
        >
        <h2
          class="font-display-lg text-2xl md:text-5xl font-bold tracking-tight text-ink-dark mb-2 md:mb-4"
        >
          Tin Tức & Kiến Thức Ngành
        </h2>
        <p class="hidden md:block text-text-muted text-base max-w-lg">
          Những chia sẻ từ hành trình sản xuất đồng phục và các dự án gần đây của chúng tôi.
        </p>
      </div>
      <a
        href={allPostsHref}
        class="home-news-all-link bg-ink-dark text-white px-5 py-2.5 md:px-6 md:py-3 rounded-full text-xs md:text-sm font-bold hover:bg-accent-gold hover:text-ink-dark transition-all shadow-soft shrink-0 self-start sm:self-auto no-underline"
      >
        Xem tất cả bài viết
      </a>
    </header>

    <!-- Mobile: slider vuốt ngang vòng lặp -->
    <div class="home-news-slider-wrap md:hidden" data-news-slider>
      <div class="home-news-slider" role="list">
        {
          sliderPosts.map((post, index) => {
            const setIndex = Math.floor(index / blogPosts.length);
            const isClone = setIndex !== 1;

            return (
              <a
                href={post.href ?? allPostsHref}
                class="home-news-slide group no-underline text-ink-dark"
                role="listitem"
                aria-hidden={isClone ? 'true' : undefined}
                tabindex={isClone ? -1 : undefined}
              >
                <figure class="home-news-slide-media m-0">
                  <img src={post.image} alt={post.alt} loading="lazy" />
                </figure>
                <div class="home-news-slide-body">
                  {post.badge && <span class="home-news-slide-badge">{post.badge}</span>}
                  <h3 class="home-news-slide-title">{post.title}</h3>
                  <p class="home-news-slide-excerpt">{post.excerpt}</p>
                  <span
                    class="home-news-slide-category"
                    style={post.categoryColor ? `color: ${post.categoryColor}` : undefined}
                  >
                    {post.category}
                  </span>
                </div>
              </a>
            );
          })
        }
      </div>
    </div>

    <!-- Desktop: featured + grid -->
    <div class="hidden md:block">
      {
        featured && (
          <article class="grid md:grid-cols-2 gap-6 md:gap-12 mb-8 md:mb-16 pb-8 md:pb-16 border-b border-border-subtle group">
            <a href={featured.href ?? allPostsHref} class="contents no-underline text-inherit">
              <figure class="relative overflow-hidden min-h-[320px] m-0 rounded-lg">
                <img
                  alt={featured.alt}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                  src={featured.image}
                  loading="lazy"
                />
              </figure>
              <div class="flex flex-col justify-center">
                {featured.badge && (
                  <span class="inline-block w-fit px-4 py-1 bg-ink-dark text-white rounded-full text-xs font-bold uppercase tracking-widest mb-5">
                    {featured.badge}
                  </span>
                )}
                <h3 class="font-display-lg text-2xl md:text-4xl leading-tight text-ink-dark mb-5">
                  {featured.title}
                </h3>
                <p class="text-body-lg text-text-muted mb-6">{featured.excerpt}</p>
                <div class="mt-auto pt-6 border-t border-border-subtle">
                  <span class="font-bold text-accent-teal">{featured.category}</span>
                </div>
              </div>
            </a>
          </article>
        )
      }
      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        {
          gridPosts.map((post) => (
            <a
              href={post.href ?? allPostsHref}
              class="group cursor-pointer no-underline text-inherit"
            >
              <div class="relative aspect-video overflow-hidden rounded-lg mb-6">
                <img
                  alt={post.alt}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.08]"
                  src={post.image}
                  loading="lazy"
                />
              </div>
              <span
                class="font-bold text-xs uppercase tracking-widest mb-4 block"
                style={post.categoryColor ? `color: ${post.categoryColor}` : undefined}
              >
                {post.category}
              </span>
              <h4 class="text-xl font-bold text-ink-dark mb-4 group-hover:text-accent-gold transition-colors">
                {post.title}
              </h4>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script src="../scripts/home-news-slider.ts"></script>
