---
interface Props {
  challenges: string[];
  solutions: string[];
  results: string[];
}

const { challenges, solutions, results } = Astro.props;

const blocks = [
  { num: '01', title: 'Thách thức', items: challenges },
  { num: '02', title: 'Giải pháp', items: solutions },
  { num: '03', title: 'Kết quả', items: results, isResult: true },
];
---

<section class="case-story" aria-label="Chi tiết dự án">
  <div class="case-story-grid">
    {
      blocks.map((block) => (
        <article class="case-story-col">
          <h2 class="case-story-label">
            <span class="case-story-num">{block.num}</span>
            {block.title}
          </h2>
          <ul class:list={['case-story-list', block.isResult && 'case-story-list--result']}>
            {block.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>
