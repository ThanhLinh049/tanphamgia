---
import { homeFeaturedCases } from '../data/site';

const { featured, secondary, quote, contact, allProjectsHref } = homeFeaturedCases;
---

<section class="home-cases py-8 md:py-14 text-white bg-ink-dark overflow-hidden" id="du-an">
  <header
    class="home-cases-header max-w-container-max-width w-full mx-auto px-6 md:px-8 pb-4 md:pb-6 flex flex-col md:flex-row justify-between items-start md:items-end gap-4 md:gap-6"
  >
    <div class="max-w-2xl">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block"
        >Case study</span
      >
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-3">Dự Án Tiêu Biểu</h2>
      <p class="text-white/60 text-base md:text-lg">
        Chứng thực năng lực qua các dự án quy mô lớn cho tập đoàn đa quốc gia.
      </p>
    </div>
    <a
      href={allProjectsHref}
      class="liquid-glass px-7 py-3 rounded-full font-bold text-sm hover:scale-105 transition-all flex items-center gap-2 whitespace-nowrap shrink-0 no-underline text-white"
    >
      Tất cả dự án →
    </a>
  </header>

  <div class="home-cases-layout max-w-container-max-width mx-auto px-6 md:px-8">
    {
      featured.href ? (
        <a href={featured.href} class="home-cases-featured group no-underline text-white">
          <img
            src={featured.image}
            alt={featured.alt}
            class="home-cases-featured-img"
            loading="lazy"
          />
          <div class="home-cases-featured-overlay">
            {featured.tag && <span class="home-cases-badge">{featured.tag}</span>}
            <h3 class="home-cases-featured-title">{featured.name}</h3>
            {featured.stats && (
              <dl class="home-cases-stats">
                {featured.stats.map((stat) => (
                  <div class="home-cases-stat">
                    <dt class="sr-only">{stat.label}</dt>
                    <dd>
                      <span class="home-cases-stat-value">{stat.value}</span>
                      <span class="home-cases-stat-label">{stat.label}</span>
                    </dd>
                  </div>
                ))}
              </dl>
            )}
          </div>
        </a>
      ) : (
        <article class="home-cases-featured group">
          <img
            src={featured.image}
            alt={featured.alt}
            class="home-cases-featured-img"
            loading="lazy"
          />
          <div class="home-cases-featured-overlay">
            {featured.tag && <span class="home-cases-badge">{featured.tag}</span>}
            <h3 class="home-cases-featured-title">{featured.name}</h3>
            {featured.stats && (
              <dl class="home-cases-stats">
                {featured.stats.map((stat) => (
                  <div class="home-cases-stat">
                    <dt class="sr-only">{stat.label}</dt>
                    <dd>
                      <span class="home-cases-stat-value">{stat.value}</span>
                      <span class="home-cases-stat-label">{stat.label}</span>
                    </dd>
                  </div>
                ))}
              </dl>
            )}
          </div>
        </article>
      )
    }

    <div class="home-cases-aside">
      <blockquote class="home-cases-quote">
        <p>"{quote.text}"</p>
        <footer class="home-cases-quote-author">— {quote.author}</footer>
      </blockquote>

      <div class="home-cases-secondary" role="list">
        {
          secondary.map((project) => (
            <a
              href={project.href}
              class="home-cases-secondary-card group no-underline text-white"
              role="listitem"
            >
              <img src={project.image} alt={project.alt} loading="lazy" />
              <div class="home-cases-secondary-body">
                <h3>{project.name}</h3>
                {project.statHighlight && (
                  <p class="home-cases-secondary-stat">
                    <span
                      class:list={[
                        'home-cases-secondary-value',
                        project.statHighlight.valueClass === 'gold' && 'text-accent-gold',
                      ]}
                    >
                      {project.statHighlight.value}
                    </span>
                    <span class="home-cases-secondary-suffix">{project.statHighlight.suffix}</span>
                  </p>
                )}
                <span class="home-cases-more">Xem chi tiết →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div class="home-cases-contact max-w-container-max-width mx-auto px-6 md:px-8 mt-4 md:mt-5">
    <span class="home-cases-contact-label">Liên hệ tư vấn</span>
    <a class="home-cases-contact-link" href={`mailto:${contact.email}`}>
      {contact.email}
    </a>
    <span class="home-cases-contact-sep" aria-hidden="true">·</span>
    <a class="home-cases-contact-link home-cases-contact-phone" href={contact.phoneHref}>
      {contact.phone}
    </a>
    <span class="home-cases-contact-sep" aria-hidden="true">·</span>
    <a class="home-cases-contact-cta" href={contact.ctaHref}>
      {contact.ctaLabel}
    </a>
  </div>
</section>
