---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import {
  gioiThieuSeo,
  brandStory,
  timeline,
  timelineSection,
  missionVision,
  coreValues,
  productionCapacity,
  teamDepartments,
  testimonials,
  certificateImages,
} from '../data/gioi-thieu';
---

<BaseLayout title={gioiThieuSeo.title} description={gioiThieuSeo.description}>
  <SiteNav currentPath="/gioi-thieu" solid />

  <!-- 2.1 Page Header -->
  <header class="relative pt-28 pb-14 md:pt-36 md:pb-20 bg-ink-dark text-white overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <img
        alt=""
        class="w-full h-full object-cover"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuD7szr7Elx-oAqCEnir2uiBqNE-4WpmIm10Kj1YsgXyu1XMFvP0qvIXYrsMpRh9sztusxsq8_7_MFPstpomb4RaDeTg9J3ldf2CSKwYUq91qGdHVM6Dm9YkfE3Rdfay_snBPthtK7WWCq_NFHZ3j3Kua1MgJAT-qQPXwlpAIQIDLIpk4Njn_msEnsXh9DyyRtwkvdNU5u10NXpGyYseM_HBo6gwnr6IFqeZ9gHXI1CrvRQnXAxx3UyIT7UIbTDEMKjd1gdxbZwWKrKl"
      />
      <div class="absolute inset-0 hero-gradient"></div>
    </div>
    <div class="relative z-10 max-w-container-max-width mx-auto px-6 md:px-8">
      <nav aria-label="Breadcrumb" class="text-sm text-white/60 mb-6">
        <a class="hover:text-accent-gold transition-colors" href="/">Trang chủ</a>
        <span class="mx-2">/</span>
        <span class="text-white">Giới thiệu</span>
      </nav>
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-4 block"
        >Về Tân Phạm Gia</span
      >
      <h1 class="font-display-lg text-3xl md:text-5xl font-extrabold tracking-tight mb-5">
        Giới thiệu
      </h1>
      <p class="text-white/80 text-base md:text-lg max-w-2xl leading-relaxed">
        Hơn 23 năm kinh nghiệm trong ngành may mặc — từ thời trang cao cấp đến giải pháp đồng phục
        doanh nghiệp toàn diện.
      </p>
    </div>
  </header>

  <!-- 2.2 Câu chuyện thương hiệu — zig-zag, không card -->
  <section class="py-16 md:py-24 bg-white border-b border-border-subtle">
    <div
      class="max-w-container-max-width mx-auto px-6 md:px-8 grid lg:grid-cols-2 gap-12 lg:gap-20 items-center"
    >
      <figure class="order-2 lg:order-1 m-0 flex justify-center lg:block">
        <img
          alt="Câu chuyện thương hiệu Tân Phạm Gia"
          class="w-full max-w-[280px] max-h-[200px] sm:max-w-sm sm:max-h-[240px] lg:max-w-none lg:max-h-none aspect-[4/3] object-cover rounded-lg"
          src={brandStory.image}
        />
      </figure>
      <div class="order-1 lg:order-2">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block"
          >Câu chuyện thương hiệu</span
        >
        <h2 class="font-headline-md text-2xl md:text-3xl font-bold text-ink-dark mb-6 leading-snug">
          {brandStory.title}
        </h2>
        <div class="space-y-4 text-text-muted leading-relaxed">
          {brandStory.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  <!-- 2.3 Hành trình 23 năm — timeline mở, không khung card -->
  <section class="py-12 md:py-16 timeline-section border-b border-border-subtle">
    <div class="max-w-container-max-width mx-auto px-6 md:px-8 mb-10 md:mb-12">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-2 block"
        >{timelineSection.eyebrow}</span
      >
      <h2 class="font-headline-md text-xl md:text-2xl lg:text-3xl font-bold text-ink-dark leading-snug max-w-3xl">
        {timelineSection.title}
      </h2>
    </div>

    <div class="timeline-rail">
      <div aria-hidden="true" class="timeline-line"></div>
      {
        timeline.map((item, i) => {
          const side = i % 2 === 0 ? 'left' : 'right';
          return (
            <div class:list={['timeline-item', `timeline-item--${side}`]}>
              {side === 'right' && <div class="timeline-gap" aria-hidden="true"></div>}

              <div class="timeline-axis">
                <span class="timeline-dot" aria-hidden="true">
                  <span class="timeline-dot-core"></span>
                </span>
                <span
                  class:list={[
                    'timeline-connector',
                    side === 'left' ? 'timeline-connector--left' : 'timeline-connector--right',
                  ]}
                  aria-hidden="true"
                />
              </div>

              <article class="timeline-entry">
                <span class="timeline-year">{item.year}</span>
                <h3 class="timeline-title">{item.title}</h3>
                <p class="timeline-desc">{item.desc}</p>
              </article>

              {side === 'left' && <div class="timeline-gap" aria-hidden="true"></div>}
            </div>
          );
        })
      }
    </div>
  </section>

  <!-- 2.4 Định vị thương hiệu — open layout -->
  <section class="py-16 md:py-24 bg-white border-b border-border-subtle">
    <div class="max-w-container-max-width mx-auto px-6 md:px-8">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block"
        >Định vị thương hiệu</span
      >
      <h2 class="font-headline-md text-2xl md:text-4xl font-bold text-ink-dark mb-12 md:mb-16">
        Sứ mệnh, Tầm nhìn & Giá trị cốt lõi
      </h2>

      <div class="grid md:grid-cols-2 gap-12 md:gap-16 mb-16 md:mb-20 pb-16 md:pb-20 border-b border-border-subtle">
        <div class="about-mission-block">
          <span class="material-symbols-outlined text-accent-gold text-3xl mb-4">flag</span>
          <h3 class="text-accent-gold font-bold uppercase tracking-wider text-sm mb-3">Sứ mệnh</h3>
          <p class="text-ink-dark/85 text-base md:text-lg leading-relaxed">{missionVision.mission}</p>
        </div>
        <div class="about-mission-block md:border-l md:border-border-subtle md:pl-16">
          <span class="material-symbols-outlined text-accent-teal text-3xl mb-4">visibility</span>
          <h3 class="text-accent-teal font-bold uppercase tracking-wider text-sm mb-3">Tầm nhìn</h3>
          <p class="text-ink-dark/85 text-base md:text-lg leading-relaxed">{missionVision.vision}</p>
        </div>
      </div>

      <h3 class="font-bold text-lg text-ink-dark mb-8 md:mb-10">5 giá trị cốt lõi</h3>
      <div class="about-value-grid">
        {
          coreValues.map((value) => (
            <div class="about-value-item">
              <span class="about-value-num">{value.num}</span>
              <div>
                <h4 class="font-bold text-ink-dark mb-2">{value.title}</h4>
                <p class="text-text-muted text-sm leading-relaxed">{value.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2.5 Năng lực sản xuất + QC — zig-zag, stats dạng bảng -->
  <section class="py-16 md:py-24 bg-white border-b border-border-subtle" id="nang-luc">
    <div class="max-w-container-max-width mx-auto px-6 md:px-8">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block"
        >Năng lực sản xuất</span
      >
      <h2 class="font-headline-md text-2xl md:text-4xl font-bold text-ink-dark mb-4">
        Quy mô & Kiểm soát chất lượng
      </h2>
      <p class="text-text-muted max-w-3xl leading-relaxed mb-10 md:mb-12">{productionCapacity.intro}</p>

      <dl class="about-stats-strip mb-16 md:mb-20 pb-16 md:pb-20 border-b border-border-subtle">
        {
          productionCapacity.stats.map((stat, i) => (
            <div
              class:list={[
                'about-stat',
                i > 0 && 'about-stat--divided',
              ]}
            >
              <dt class="about-stat-value">{stat.value}</dt>
              <dd class="about-stat-label">{stat.label}</dd>
            </div>
          ))
        }
      </dl>

      <div class="flex flex-col md:flex-row items-center gap-10 md:gap-20 mb-16 md:mb-20">
        <figure class="flex-1 w-full m-0">
          <img
            alt="Nhà xưởng Tân Phạm Gia"
            class="w-full aspect-[4/3] object-cover rounded-lg"
            src={productionCapacity.factoryImage}
          />
        </figure>
        <div class="flex-1 w-full">
          <span class="font-eyebrow text-eyebrow text-accent-gold mb-4 block">QUY MÔ SẢN XUẤT</span>
          <h3 class="font-headline-md text-2xl md:text-3xl font-bold mb-4 text-ink-dark">
            Xưởng may 2.000m² đạt chuẩn quốc tế
          </h3>
          <p class="text-text-muted leading-relaxed">
            Với hệ thống máy móc hiện đại nhập khẩu từ Nhật Bản và Đức, Tân Phạm Gia sở hữu năng lực
            đáp ứng những đơn hàng khắt khe nhất về kỹ thuật và mỹ thuật.
          </p>
        </div>
      </div>

      <div class="flex flex-col md:flex-row-reverse items-center gap-10 md:gap-20">
        <figure class="flex-1 w-full m-0">
          <img
            alt="Quy trình QC"
            class="w-full aspect-[4/3] object-cover rounded-lg"
            src={productionCapacity.qcImage}
          />
        </figure>
        <div class="flex-1 w-full">
          <span class="font-eyebrow text-eyebrow text-accent-gold mb-4 block"
            >CHẤT LƯỢNG LÀM GỐC</span
          >
          <h3 class="font-headline-md text-2xl md:text-3xl font-bold mb-4 text-ink-dark">
            {productionCapacity.qcTitle}
          </h3>
          <p class="text-text-muted mb-6 leading-relaxed">{productionCapacity.qcDesc}</p>
          <ul class="grid grid-cols-2 gap-x-4 gap-y-3">
            {
              productionCapacity.qcStandards.map((std) => (
                <li class="flex items-center gap-2 font-semibold text-sm text-ink-dark">
                  <span class="w-1.5 h-1.5 rounded-full bg-accent-gold shrink-0"></span>
                  {std}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 2.6 Đội ngũ nhân sự — grid icon, không card -->
  <section class="py-16 md:py-24 bg-white border-b border-border-subtle">
    <div class="max-w-container-max-width mx-auto px-6 md:px-8">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block"
        >Con người Tân Phạm Gia</span
      >
      <h2 class="font-headline-md text-2xl md:text-4xl font-bold text-ink-dark mb-12 md:mb-14">
        Đội ngũ nhân sự
      </h2>
      <div class="about-team-grid">
        {
          teamDepartments.map((dept) => (
            <div class="about-team-item">
              <div class="about-team-head">
                <span class="text-accent-gold font-bold text-sm">{dept.num}</span>
                <span class="material-symbols-outlined text-accent-teal text-2xl">{dept.icon}</span>
              </div>
              <h3 class="font-bold text-ink-dark mb-2">{dept.title}</h3>
              <p class="text-text-muted text-sm leading-relaxed">{dept.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2.7 Giấy khen & chứng nhận — figure gallery -->
  <section class="py-16 md:py-24 bg-white border-b border-border-subtle" id="chung-nhan">
    <div class="max-w-container-max-width mx-auto px-6 md:px-8">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block"
        >Uy tín & Chứng nhận</span
      >
      <h2 class="font-headline-md text-2xl md:text-3xl font-bold text-ink-dark mb-10 md:mb-12">
        Giấy khen & Chứng nhận
      </h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {
          certificateImages.map((cert) => (
            <figure class="about-cert-figure m-0">
              <img
                alt={cert.title}
                class="w-full aspect-[4/3] object-cover rounded-lg"
                loading="lazy"
                src={cert.image}
              />
              <figcaption class="mt-3 text-sm font-semibold text-ink-dark">{cert.title}</figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2.8 Testimonial — quote mở, không khung card -->
  <section class="py-16 md:py-24 bg-ink-dark text-white">
    <div class="max-w-container-max-width mx-auto px-6 md:px-8">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block"
        >Phản hồi khách hàng</span
      >
      <h2 class="font-headline-md text-2xl md:text-4xl font-bold mb-12 md:mb-14">
        Khách hàng nói gì về chúng tôi
      </h2>
      <div class="grid md:grid-cols-3 gap-10 md:gap-12">
        {
          testimonials.map((t, i) => (
            <blockquote
              class:list={[
                'about-quote m-0',
                i > 0 && 'md:border-l md:border-white/15 md:pl-10',
              ]}
            >
              <p class="text-white/90 leading-relaxed mb-6">"{t.quote}"</p>
              <footer>
                <cite class="not-italic font-bold text-accent-gold block">{t.name}</cite>
                <span class="text-white/60 text-sm mt-1 block">{t.role}</span>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 2.9 CTA — được phép dùng vùng nhấn theo .cursorrules -->
  <section class="py-16 md:py-24 bg-accent-gold-light">
    <div class="max-w-container-max-width mx-auto px-6 md:px-8 text-center">
      <h2 class="font-display-lg text-3xl md:text-5xl font-bold mb-4 leading-tight text-ink-dark">
        Sẵn sàng cho dự án đồng phục của bạn?
      </h2>
      <p class="text-ink-dark/75 mb-8 max-w-xl mx-auto">
        Liên hệ ngay để nhận tư vấn miễn phí và báo giá chi tiết cho doanh nghiệp của bạn.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/lien-he"
          class="bg-ink-dark text-white px-6 py-3 text-sm md:px-10 md:py-4 md:text-base rounded-full font-bold hover:scale-105 transition-all text-center"
          >Nhận tư vấn giải pháp</a
        >
        <a
          href="/tai-lieu"
          class="border-2 border-ink-dark text-ink-dark px-6 py-3 text-sm md:px-10 md:py-4 md:text-base rounded-full font-bold hover:bg-ink-dark hover:text-white transition-all text-center"
          >Tải hồ sơ năng lực</a
        >
      </div>
    </div>
  </section>

  <SiteFooter />
</BaseLayout>
