---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteNav from '../../../../components/SiteNav.astro';
import SiteFooter from '../../../../components/SiteFooter.astro';
import CaseStudyStory from '../../../../components/CaseStudyStory.astro';
import { duAnGiaiPhap2 } from '../../../../data/giai-phap-2-du-an';

export function getStaticPaths() {
  return duAnGiaiPhap2.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const otherProjects = duAnGiaiPhap2.filter((item) => item.slug !== project.slug);
---

<BaseLayout
  title={`${project.name} | Dự án tiêu biểu — Giải pháp 2`}
  description={`Case study ${project.name} — đồng phục văn phòng & tập đoàn.`}
>
  <SiteNav solid currentPath="/giai-phap/giai-phap-2" />
  <main class="solution-detail-page solution-style-industrial">
    <section class="solution-detail-section pt-28 md:pt-32">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <a
          href="/giai-phap/giai-phap-2#du-an"
          class="text-sm font-semibold text-accent-teal hover:text-ink-dark transition-colors"
        >
          ← Quay lại Giải pháp 2
        </a>
        <div class="solution-hero-grid grid lg:grid-cols-2 gap-10 items-start mt-5">
          <div>
            <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block">
              Dự án tiêu biểu
            </span>
            <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-4">{project.name}</h1>
            <p class="text-text-muted text-sm md:text-base mb-2">{project.stats}</p>
            {project.field && (
              <p class="text-sm text-ink-dark/75 mb-4">Lĩnh vực: {project.field}</p>
            )}
            <p class="text-text-muted text-base md:text-lg leading-relaxed">{project.intro}</p>
          </div>
          <figure class="m-0">
            <img
              src={project.image}
              alt={project.name}
              class="w-full aspect-[4/3] object-cover rounded-lg border-2 border-[#f2c300]"
            />
          </figure>
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <CaseStudyStory
          challenges={project.challenges}
          solutions={project.solutions}
          results={project.results}
        />
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-6">Dự án khác</h2>
        <div class="solution-box-grid solution-box-grid--compact">
          {
            otherProjects.map((item) => (
              <article class="solution-box-item">
                <a
                  class="solution-box-summary no-underline"
                  href={`/giai-phap/giai-phap-2/du-an/${item.slug}`}
                >
                  <figure class="solution-box-media m-0">
                    <img
                      class="w-full h-full object-cover"
                      src={item.image}
                      alt={item.name}
                      loading="lazy"
                    />
                  </figure>
                  <h3 class="solution-box-title">{item.name}</h3>
                  <p class="solution-box-desc">{item.stats}</p>
                  <span class="solution-box-link">Xem chi tiết</span>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <div class="bg-[#f2c300] px-6 py-10 md:px-10 text-center">
          <h2 class="text-2xl md:text-3xl font-bold text-black mb-3">Cần giải pháp tương tự?</h2>
          <p class="text-black/75 mb-6">
            Đội ngũ Tân Phạm Gia tư vấn đồng phục văn phòng & tập đoàn quy mô lớn.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/#tai-lieu" class="px-6 py-3 bg-black text-white text-sm font-semibold rounded-full">
              Nhận tư vấn ngay
            </a>
            <a
              href="/giai-phap/giai-phap-2"
              class="px-6 py-3 border border-black text-black text-sm font-semibold rounded-full"
            >
              Xem Giải pháp 2
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
