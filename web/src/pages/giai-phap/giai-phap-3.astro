---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { solutions } from '../../data/site';
import SolutionPlanSplit from '../../components/SolutionPlanSplit.astro';
import { duAnGiaiPhap3 } from '../../data/giai-phap-3-du-an';

const solution = solutions.find((item) => item.slug === 'giai-phap-3');
const relatedSolutions = solutions.filter((item) => item.slug !== 'giai-phap-3');

const industries = [
  'FMCG & Hàng tiêu dùng nhanh',
  'Hệ thống phân phối',
  'Đội ngũ Sales thị trường',
  'PG/PB & Activation',
];

const issues = [
  'Hình ảnh đội ngũ không đồng nhất giữa các khu vực — màu sắc, logo hoặc chất lượng khác nhau giữa các đợt triển khai, giảm nhận diện tại điểm bán.',
  'Đồng phục không phù hợp tính chất di chuyển liên tục — nóng, bí, nhanh xuống cấp, ảnh hưởng trải nghiệm và tăng chi phí thay mới.',
  'Khó quản lý đồng phục khi phát sinh nhân sự mới — mất thời gian tổng hợp size, chậm cấp phát, dễ sai lệch giữa các đợt đặt hàng.',
  'Triển khai trên nhiều tỉnh thành gặp khó khăn — khó đồng bộ hình ảnh thương hiệu, phát sinh sai sót giao nhận, tăng khối lượng công việc hành chính.',
];

const plans = [
  {
    title: 'Chuẩn hóa nhận diện trên toàn hệ thống',
    desc: 'Thống nhất màu sắc, logo, chất liệu và quy cách sản xuất — hình ảnh thương hiệu đồng bộ trên toàn quốc.',
  },
  {
    title: 'Tư vấn thiết kế & chất liệu theo môi trường làm việc',
    desc: 'Phân tích đặc thù công việc và tần suất sử dụng để gia tăng sự thoải mái cho đội ngũ di chuyển ngoài thị trường.',
  },
  {
    title: 'Quản lý hồ sơ kỹ thuật cho đơn tái đặt',
    desc: 'Lưu trữ thông số kỹ thuật, bảng size, màu sắc và hồ sơ sản xuất — duy trì đồng nhất giữa các đợt và khu vực.',
  },
  {
    title: 'Triển khai linh hoạt cho hệ thống nhiều tỉnh thành',
    desc: 'Hỗ trợ đóng gói, phân loại và giao hàng theo khu vực hoặc danh sách nhân sự, giảm tải hành chính.',
  },
  {
    title: 'Năng lực sản xuất số lượng lớn',
    desc: 'Đáp ứng linh hoạt từ vài trăm đến hàng chục nghìn sản phẩm cho chiến dịch hoặc mở rộng hệ thống.',
  },
];

const processSteps = [
  'Tiếp nhận yêu cầu & tư vấn chuyên sâu',
  'Thiết kế & báo giá',
  'May mẫu thử & duyệt mẫu',
  'Ký kết hợp đồng',
  'Sản xuất & kiểm soát chất lượng',
  'Bàn giao & hậu mãi',
];
---

<BaseLayout
  title="Giải pháp 3 | FMCG & Chuỗi phân phối"
  description="Giải pháp đồng phục FMCG và chuỗi phân phối."
>
  <SiteNav solid currentPath="/#giai-phap" />
  <main class="solution-detail-page solution-style-industrial">
    <section class="pt-28 md:pt-32 pb-14 md:pb-20 border-b border-border-subtle">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <a href="/#giai-phap" class="text-sm font-semibold text-accent-teal hover:text-ink-dark transition-colors">
          ← Quay lại
        </a>
        <div class="solution-hero-grid grid lg:grid-cols-2 gap-10 items-start mt-5">
          <div>
            <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block">Giải pháp 3</span>
            <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-5">Đồng phục FMCG & Chuỗi phân phối</h1>
            <p class="text-text-muted text-base md:text-lg leading-relaxed mb-6">
              Giải pháp đồng phục giúp doanh nghiệp FMCG, Sales thị trường và hệ thống phân phối chuẩn hóa hình
              ảnh thương hiệu, nâng cao độ nhận diện tại điểm bán và quản lý hiệu quả đội ngũ trải dài trên nhiều
              tỉnh thành.
            </p>
            <ul class="solution-industry-list text-sm md:text-base">
              {
                industries.map((item) => (
                  <li class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent-teal shrink-0" />
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
          <figure class="m-0">
            <img
              src={solution?.image}
              alt="Giải pháp FMCG và chuỗi phân phối"
              class="w-full aspect-[4/3] object-cover rounded-lg"
            />
          </figure>
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8 max-w-4xl">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">01. Những vấn đề doanh nghiệp FMCG thường gặp</h2>
        <div class="solution-issue-grid">
          {
            issues.map((issue, idx) => (
              <article class="solution-issue-card">
                <span class="num">{idx + 1}</span>
                <p class="text-sm text-ink-dark/85 leading-relaxed">{issue}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">02. Giải pháp từ Tân Phạm Gia</h2>
        <SolutionPlanSplit
          image={solution?.image ?? ''}
          imageAlt="Giải pháp FMCG và chuỗi phân phối"
          items={plans}
        />
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">03. Giải pháp sản phẩm & chất liệu</h2>
        <ul class="grid sm:grid-cols-3 gap-4 mb-8 text-sm md:text-base">
          <li class="py-3 border-b border-border-subtle">Áo Polo Sales thị trường</li>
          <li class="py-3 border-b border-border-subtle">Áo Polo nhận diện thương hiệu</li>
          <li class="py-3 border-b border-border-subtle">Áo T-Shirt Activation</li>
          <li class="py-3 border-b border-border-subtle">Đồng phục PG/PB</li>
          <li class="py-3 border-b border-border-subtle">Nón & Phụ kiện nhận diện thương hiệu</li>
        </ul>
        <div class="overflow-x-auto border border-border-subtle">
          <table class="w-full min-w-[860px] text-sm">
            <thead class="bg-surface-muted">
              <tr class="text-left">
                <th class="px-4 py-3 font-semibold">Chất liệu</th>
                <th class="px-4 py-3 font-semibold">Thành phần</th>
                <th class="px-4 py-3 font-semibold">Đặc tính nổi bật</th>
                <th class="px-4 py-3 font-semibold">Môi trường phù hợp</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Coolmax Pique</td>
                <td class="px-4 py-3 text-text-muted">100% Poly thoát nhiệt</td>
                <td class="px-4 py-3 text-text-muted">Thoáng mát, mau khô, kháng mùi</td>
                <td class="px-4 py-3 text-text-muted">Sales field, thị trường ngoài trời</td>
              </tr>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Pique Lacoste</td>
                <td class="px-4 py-3 text-text-muted">100% Poly cao cấp</td>
                <td class="px-4 py-3 text-text-muted">Bề mặt đẹp, giữ form, màu chuẩn Pantone</td>
                <td class="px-4 py-3 text-text-muted">Hội nghị đại lý, sự kiện thương hiệu</td>
              </tr>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Pique Tici (CVC)</td>
                <td class="px-4 py-3 text-text-muted">65% Cotton, 35% Poly</td>
                <td class="px-4 py-3 text-text-muted">Mềm, thấm hút, in màu sắc nét</td>
                <td class="px-4 py-3 text-text-muted">Nhân viên chuỗi cửa hàng</td>
              </tr>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Polyester Dri-fit</td>
                <td class="px-4 py-3 text-text-muted">100% Poly thoát ẩm</td>
                <td class="px-4 py-3 text-text-muted">Mau khô, thoáng khí, màu tươi bền</td>
                <td class="px-4 py-3 text-text-muted">Activation, roadshow, ngoài trời</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="solution-detail-section" id="du-an">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">04. Dự án tiêu biểu</h2>
        <div class="solution-case-grid">
          {
            duAnGiaiPhap3.map((project) => (
              <a
                href={`/giai-phap/giai-phap-3/du-an/${project.slug}`}
                class="solution-case-card solution-case-link group"
              >
                <img src={project.image} alt={project.name} />
                <div class="solution-case-body">
                  <h3 class="font-bold">{project.name}</h3>
                  <p class="text-xs text-white/80 mt-1">{project.stats.split(' | ').slice(0, 2).join(' | ')}</p>
                  <span class="solution-case-more">Xem chi tiết</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">05. Quy trình làm việc - giảm rủi ro cho doanh nghiệp</h2>
        <div class="solution-step-grid">
          {
            processSteps.map((step, index) => (
              <article class="solution-step-item">
                <span class="num">{index + 1}</span>
                <h3 class="font-bold mb-1">Bước {index + 1}: {step}</h3>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-6">06. Tìm hiểu thêm</h2>
        <div class="solution-box-grid solution-box-grid--compact">
          {
            relatedSolutions.map((item) => (
              <article class="solution-box-item">
                <a class="solution-box-summary no-underline" href={`/giai-phap/${item.slug}`}>
                  <figure class="solution-box-media m-0">
                    <img class="w-full h-full object-cover" src={item.image} alt={item.title} loading="lazy" />
                  </figure>
                  <span class="solution-box-number">{item.slug.replace('giai-phap-', '0')}</span>
                  <h3 class="solution-box-title">{item.title}</h3>
                  <p class="solution-box-desc">{item.desc}</p>
                  <span class="solution-box-link">Xem chi tiết</span>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <div class="solution-cta-banner bg-[#f2c300] px-6 py-10 md:px-10 text-center">
          <h2 class="text-2xl md:text-3xl font-bold text-black mb-3">Tăng độ nhận diện tại mọi điểm bán</h2>
          <p class="text-black/75 mb-6">
            Giải pháp dành riêng cho đội ngũ FMCG, sales thị trường và hệ thống phân phối đa tỉnh thành.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/#tai-lieu" class="px-6 py-3 bg-black text-white text-sm font-semibold rounded-full">
              Nhận tư vấn ngay
            </a>
            <a href="/#tai-lieu" class="px-6 py-3 border border-black text-black text-sm font-semibold rounded-full">
              Tải hồ sơ năng lực
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
