---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { solutions } from '../../data/site';
import SolutionPlanSplit from '../../components/SolutionPlanSplit.astro';
import { duAnGiaiPhap4 } from '../../data/giai-phap-4-du-an';

const solution = solutions.find((item) => item.slug === 'giai-phap-4');
const relatedSolutions = solutions.filter((item) => item.slug !== 'giai-phap-4');

const industries = [
  'Phòng khám & Trung tâm y tế',
  'Nha khoa',
  'Thẩm mỹ viện & Spa',
  'Chuỗi chăm sóc sức khỏe',
  'Trung tâm đào tạo',
];

const issues = [
  'Đồng phục chưa phản ánh đúng hình ảnh thương hiệu — form dáng lỗi thời, màu sắc thiếu đồng nhất, giảm cảm nhận chuyên nghiệp và sự tin tưởng của khách hàng.',
  'Chất liệu không phù hợp cường độ sử dụng cao — nhân sự không thoải mái khi làm việc lâu, tăng tần suất thay mới đồng phục.',
  'Đồng phục giữa các chi nhánh không đồng nhất — mất tính nhận diện thương hiệu, khó quản lý khi mở rộng hệ thống.',
  'Thiếu sự khác biệt giữa các vị trí nhân sự — khách hàng khó nhận biết chức năng từng bộ phận, giảm trải nghiệm dịch vụ.',
];

const plans = [
  {
    title: 'Thiết kế đồng phục theo hình ảnh thương hiệu',
    desc: 'Tư vấn màu sắc, kiểu dáng và chi tiết nhận diện phù hợp định vị — gia tăng sự chuyên nghiệp từ điểm chạm đầu tiên.',
  },
  {
    title: 'Tư vấn thiết kế & chất liệu theo môi trường làm việc',
    desc: 'Phân tích đặc thù công việc và tần suất sử dụng, đảm bảo thoải mái và tính thẩm mỹ.',
  },
  {
    title: 'Phân nhóm đồng phục theo chức danh',
    desc: 'Giải pháp riêng cho lễ tân, tư vấn viên, điều dưỡng, kỹ thuật viên hoặc quản lý — khách hàng dễ nhận diện.',
  },
  {
    title: 'Chuẩn hóa đồng phục cho hệ thống nhiều chi nhánh',
    desc: 'Lưu trữ hồ sơ kỹ thuật, bảng size và tiêu chuẩn sản xuất — duy trì tính đồng nhất khi mở rộng.',
  },
  {
    title: 'Quản lý chất lượng xuyên suốt dự án',
    desc: 'Kiểm soát từ nguyên phụ liệu đến thành phẩm, đảm bảo tiêu chuẩn sử dụng và hình ảnh thương hiệu.',
  },
];

const processSteps = [
  'Tiếp nhận yêu cầu & tư vấn chuyên sâu',
  'Thiết kế & báo giá',
  'May mẫu thử & duyệt mẫu',
  'Ký kết hợp đồng',
  'Sản xuất & kiểm soát chất lượng',
  'Bàn giao & hậu mãi',
];
---

<BaseLayout
  title="Giải pháp 4 | Y tế, Spa & Dịch vụ"
  description="Giải pháp đồng phục y tế, spa và dịch vụ."
>
  <SiteNav solid currentPath="/#giai-phap" />
  <main class="solution-detail-page solution-style-industrial">
    <section class="pt-28 md:pt-32 pb-14 md:pb-20 border-b border-border-subtle">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <a href="/#giai-phap" class="text-sm font-semibold text-accent-teal hover:text-ink-dark transition-colors">
          ← Quay lại
        </a>
        <div class="solution-hero-grid grid lg:grid-cols-2 gap-10 items-start mt-5">
          <div>
            <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block">Giải pháp 4</span>
            <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-5">Đồng phục Y tế, Spa & Dịch vụ</h1>
            <p class="text-text-muted text-base md:text-lg leading-relaxed mb-6">
              Giải pháp đồng phục chuyên nghiệp giúp nâng cao hình ảnh thương hiệu, gia tăng trải nghiệm khách hàng
              và đảm bảo sự thoải mái cho đội ngũ nhân sự trong quá trình làm việc.
            </p>
            <ul class="solution-industry-list text-sm md:text-base">
              {
                industries.map((item) => (
                  <li class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent-teal shrink-0" />
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
          <figure class="m-0">
            <img
              src={solution?.image}
              alt="Giải pháp y tế spa dịch vụ"
              class="w-full aspect-[4/3] object-cover rounded-lg"
            />
          </figure>
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8 max-w-4xl">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">
          01. Những vấn đề doanh nghiệp Y tế, Spa & Dịch vụ thường gặp
        </h2>
        <div class="solution-issue-grid">
          {
            issues.map((issue, idx) => (
              <article class="solution-issue-card">
                <span class="num">{idx + 1}</span>
                <p class="text-sm text-ink-dark/85 leading-relaxed">{issue}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">02. Giải pháp từ Tân Phạm Gia</h2>
        <SolutionPlanSplit
          image={solution?.image ?? ''}
          imageAlt="Giải pháp y tế spa dịch vụ"
          items={plans}
        />
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">03. Giải pháp sản phẩm & chất liệu</h2>
        <ul class="grid sm:grid-cols-3 gap-4 mb-8 text-sm md:text-base">
          <li class="py-3 border-b border-border-subtle">Đồng phục bác sĩ</li>
          <li class="py-3 border-b border-border-subtle">Đồng phục điều dưỡng</li>
          <li class="py-3 border-b border-border-subtle">Đồng phục nha khoa</li>
          <li class="py-3 border-b border-border-subtle">Đồng phục spa</li>
          <li class="py-3 border-b border-border-subtle">Phụ kiện nhận diện thương hiệu</li>
        </ul>
        <div class="overflow-x-auto border border-border-subtle">
          <table class="w-full min-w-[860px] text-sm">
            <thead class="bg-surface-muted">
              <tr class="text-left">
                <th class="px-4 py-3 font-semibold">Chất liệu</th>
                <th class="px-4 py-3 font-semibold">Thành phần</th>
                <th class="px-4 py-3 font-semibold">Đặc tính nổi bật</th>
                <th class="px-4 py-3 font-semibold">Môi trường phù hợp</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Poly kháng khuẩn nano</td>
                <td class="px-4 py-3 text-text-muted">100% Poly xử lý nano</td>
                <td class="px-4 py-3 text-text-muted">Kháng khuẩn, chống bám bụi, mau khô</td>
                <td class="px-4 py-3 text-text-muted">Bệnh viện, phòng khám</td>
              </tr>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Poly Spun trắng</td>
                <td class="px-4 py-3 text-text-muted">100% Poly</td>
                <td class="px-4 py-3 text-text-muted">Giữ trắng lâu, chống nhăn, dễ là</td>
                <td class="px-4 py-3 text-text-muted">Áo blouse bác sĩ</td>
              </tr>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Cotton-Spandex mềm</td>
                <td class="px-4 py-3 text-text-muted">92% Cotton, 8% Spandex</td>
                <td class="px-4 py-3 text-text-muted">Mềm mịn, co giãn nhẹ, thoải mái</td>
                <td class="px-4 py-3 text-text-muted">Spa, massage, thẩm mỹ</td>
              </tr>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Vải dễ giặt nhanh khô</td>
                <td class="px-4 py-3 text-text-muted">Poly pha dệt kháng nước nhẹ</td>
                <td class="px-4 py-3 text-text-muted">Mau khô, giữ dáng tốt</td>
                <td class="px-4 py-3 text-text-muted">Giặt hàng ngày, tần suất cao</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="solution-detail-section" id="du-an">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">04. Dự án tiêu biểu</h2>
        <div class="solution-case-grid">
          {
            duAnGiaiPhap4.map((project) => (
              <a
                href={`/giai-phap/giai-phap-4/du-an/${project.slug}`}
                class="solution-case-card solution-case-link group"
              >
                <img src={project.image} alt={project.name} />
                <div class="solution-case-body">
                  <h3 class="font-bold">{project.name}</h3>
                  <p class="text-xs text-white/80 mt-1">{project.stats.split(' | ').slice(0, 2).join(' | ')}</p>
                  <span class="solution-case-more">Xem chi tiết</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">05. Quy trình làm việc - giảm rủi ro cho doanh nghiệp</h2>
        <div class="solution-step-grid">
          {
            processSteps.map((step, index) => (
              <article class="solution-step-item">
                <span class="num">{index + 1}</span>
                <h3 class="font-bold mb-1">Bước {index + 1}: {step}</h3>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-6">06. Tìm hiểu thêm</h2>
        <div class="solution-box-grid solution-box-grid--compact">
          {
            relatedSolutions.map((item) => (
              <article class="solution-box-item">
                <a class="solution-box-summary no-underline" href={`/giai-phap/${item.slug}`}>
                  <figure class="solution-box-media m-0">
                    <img class="w-full h-full object-cover" src={item.image} alt={item.title} loading="lazy" />
                  </figure>
                  <span class="solution-box-number">{item.slug.replace('giai-phap-', '0')}</span>
                  <h3 class="solution-box-title">{item.title}</h3>
                  <p class="solution-box-desc">{item.desc}</p>
                  <span class="solution-box-link">Xem chi tiết</span>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <div class="solution-cta-banner bg-[#f2c300] px-6 py-10 md:px-10 text-center">
          <h2 class="text-2xl md:text-3xl font-bold text-black mb-3">Đồng phục dịch vụ chỉn chu từ điểm chạm đầu tiên</h2>
          <p class="text-black/75 mb-6">
            Giải pháp chuyên biệt cho Y tế, Spa và dịch vụ giúp nâng trải nghiệm khách hàng và đội ngũ vận hành.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/#tai-lieu" class="px-6 py-3 bg-black text-white text-sm font-semibold rounded-full">
              Nhận tư vấn ngay
            </a>
            <a href="/#tai-lieu" class="px-6 py-3 border border-black text-black text-sm font-semibold rounded-full">
              Tải hồ sơ năng lực
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
