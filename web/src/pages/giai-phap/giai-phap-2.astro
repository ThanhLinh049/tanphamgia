---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { solutions } from '../../data/site';
import SolutionPlanSplit from '../../components/SolutionPlanSplit.astro';
import { duAnGiaiPhap2 } from '../../data/giai-phap-2-du-an';

const solution = solutions.find((item) => item.slug === 'giai-phap-2');
const relatedSolutions = solutions.filter((item) => item.slug !== 'giai-phap-2');

const industries = [
  'Tập đoàn & Tổng công ty',
  'Doanh nghiệp dịch vụ',
  'Ngân hàng & Tài chính',
  'Bất động sản',
  'Logistics & Chuỗi văn phòng',
];

const issues = [
  'Đồng phục thiếu tính thời trang, form dáng rộng cứng — nhân viên không tự tin, hình ảnh doanh nghiệp thiếu chuyên nghiệp.',
  'Một mẫu đồng phục dùng chung cho lễ tân, kinh doanh, quản lý — trải nghiệm mặc không tối ưu, khó thể hiện đặc thù từng bộ phận.',
  'Đồng phục giữa các đợt đặt hàng không đồng nhất về màu sắc, chất liệu hoặc form dáng — mất tính nhận diện thương hiệu.',
  'Đồng phục nhanh xuống cấp sau thời gian ngắn — chất liệu bai nhão, tăng chi phí thay mới.',
];

const plans = [
  {
    title: 'Phát triển đồng phục theo tư duy thời trang ứng dụng',
    desc: 'Vừa chuyên nghiệp vừa giúp người mặc tự tin hơn trong công việc.',
  },
  {
    title: 'Tư vấn thiết kế & chất liệu phù hợp mục đích sử dụng',
    desc: 'Phân tích vai trò công việc, tần suất và môi trường làm việc thay vì áp dụng một mẫu cho toàn bộ doanh nghiệp.',
  },
  {
    title: 'Công nghệ rập 3D & chuẩn hóa form dáng',
    desc: 'Tôn dáng người mặc, phù hợp nhiều vóc dáng, tạo sự khác biệt tinh tế.',
  },
  {
    title: 'Lưu trữ hồ sơ kỹ thuật',
    desc: 'Đồng bộ toàn hệ thống, đảm bảo đồng nhất giữa nhiều lần tái đặt hàng.',
  },
];

const processSteps = [
  'Tiếp nhận yêu cầu & Tư vấn chuyên sâu',
  'Thiết kế & Báo giá',
  'May mẫu thử & Duyệt mẫu',
  'Ký kết hợp đồng',
  'Sản xuất & Kiểm soát chất lượng',
  'Bàn giao & Hậu mãi',
];
---

<BaseLayout
  title="Giải pháp 2 | Văn phòng & Tập đoàn"
  description="Giải pháp đồng phục văn phòng và tập đoàn."
>
  <SiteNav solid currentPath="/#giai-phap" />
  <main class="solution-detail-page solution-style-industrial">
    <section class="pt-28 md:pt-32 pb-14 md:pb-20 border-b border-border-subtle">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <a href="/#giai-phap" class="text-sm font-semibold text-accent-teal hover:text-ink-dark transition-colors">
          ← Quay lại
        </a>
        <div class="solution-hero-grid grid lg:grid-cols-2 gap-10 items-start mt-5">
          <div>
            <span class="text-xs font-bold uppercase tracking-[0.2em] text-accent-teal mb-3 block">Giải pháp 2</span>
            <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-5">Đồng phục Văn phòng & Tập đoàn</h1>
            <p class="text-text-muted text-base md:text-lg leading-relaxed mb-6">
              Giải pháp đồng phục chuyên nghiệp giúp doanh nghiệp chuẩn hóa hình ảnh thương hiệu, nâng cao trải
              nghiệm nhân sự và duy trì sự đồng nhất trong toàn hệ thống từ 100 đến 5.000+ nhân sự.
            </p>
            <ul class="solution-industry-list text-sm md:text-base">
              {
                industries.map((item) => (
                  <li class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-accent-teal shrink-0" />
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
          <figure class="m-0">
            <img
              src={solution?.image}
              alt="Giải pháp văn phòng và tập đoàn"
              class="w-full aspect-[4/3] object-cover rounded-lg"
            />
          </figure>
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8 max-w-4xl">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">01. Những vấn đề doanh nghiệp thường gặp khi đặt đồng phục</h2>
        <div class="solution-issue-grid">
          {
            issues.map((issue, idx) => (
              <article class="solution-issue-card">
                <span class="num">{idx + 1}</span>
                <p class="text-sm text-ink-dark/85 leading-relaxed">{issue}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">02. Giải pháp từ Tân Phạm Gia</h2>
        <SolutionPlanSplit
          image={solution?.image ?? ''}
          imageAlt="Giải pháp văn phòng và tập đoàn"
          items={plans}
        />
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">03. Danh mục sản phẩm & thông số kỹ thuật vải</h2>
        <ul class="grid sm:grid-cols-3 gap-4 mb-8 text-sm md:text-base">
          <li class="py-3 border-b border-border-subtle">Áo sơ mi công sở</li>
          <li class="py-3 border-b border-border-subtle">Áo Polo doanh nghiệp</li>
          <li class="py-3 border-b border-border-subtle">Áo T-Shirt thể thao</li>
          <li class="py-3 border-b border-border-subtle">Áo khoác</li>
          <li class="py-3 border-b border-border-subtle">Quần / Chân váy</li>
        </ul>
        <div class="overflow-x-auto border border-border-subtle">
          <table class="w-full min-w-[860px] text-sm">
            <thead class="bg-surface-muted">
              <tr class="text-left">
                <th class="px-4 py-3 font-semibold">Chất liệu</th>
                <th class="px-4 py-3 font-semibold">Thành phần</th>
                <th class="px-4 py-3 font-semibold">Đặc tính nổi bật</th>
                <th class="px-4 py-3 font-semibold">Môi trường phù hợp</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Oxford Cotton</td>
                <td class="px-4 py-3 text-text-muted">100% Cotton / CVC</td>
                <td class="px-4 py-3 text-text-muted">Mềm mại, thấm hút, giữ form tốt</td>
                <td class="px-4 py-3 text-text-muted">Văn phòng, lễ tân</td>
              </tr>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Pique Tici (CVC)</td>
                <td class="px-4 py-3 text-text-muted">65% Cotton, 35% Poly</td>
                <td class="px-4 py-3 text-text-muted">Thoáng khí, bền màu, in logo sắc nét</td>
                <td class="px-4 py-3 text-text-muted">Polo văn phòng, kinh doanh</td>
              </tr>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Polyester cao cấp</td>
                <td class="px-4 py-3 text-text-muted">100% Poly</td>
                <td class="px-4 py-3 text-text-muted">Chống nhăn, mau khô, dễ bảo quản</td>
                <td class="px-4 py-3 text-text-muted">Đội ngũ di chuyển nhiều</td>
              </tr>
              <tr class="border-t border-border-subtle">
                <td class="px-4 py-3">Kaki Việt Nam</td>
                <td class="px-4 py-3 text-text-muted">95% Poly, 5% Spandex</td>
                <td class="px-4 py-3 text-text-muted">Co giãn nhẹ, chống nhăn, lịch sự</td>
                <td class="px-4 py-3 text-text-muted">Quản lý, điều hành</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="solution-detail-section" id="du-an">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">04. Dự án tiêu biểu</h2>
        <div class="solution-case-grid">
          {
            duAnGiaiPhap2.map((project) => (
              <a
                href={`/giai-phap/giai-phap-2/du-an/${project.slug}`}
                class="solution-case-card solution-case-link group"
              >
                <img src={project.image} alt={project.name} />
                <div class="solution-case-body">
                  <h3 class="font-bold">{project.name}</h3>
                  <p class="text-xs text-white/80 mt-1">{project.stats.split(' | ').slice(0, 2).join(' | ')}</p>
                  <span class="solution-case-more">Xem chi tiết</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-8">05. Quy trình làm việc - giảm rủi ro cho doanh nghiệp</h2>
        <div class="solution-step-grid">
          {
            processSteps.map((step, index) => (
              <article class="solution-step-item">
                <span class="num">{index + 1}</span>
                <h3 class="font-bold mb-1">Bước {index + 1}: {step}</h3>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="solution-detail-section">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <h2 class="text-2xl md:text-3xl font-bold mb-6">06. Tìm hiểu thêm</h2>
        <div class="solution-box-grid solution-box-grid--compact">
          {
            relatedSolutions.map((item) => (
              <article class="solution-box-item">
                <a class="solution-box-summary no-underline" href={`/giai-phap/${item.slug}`}>
                  <figure class="solution-box-media m-0">
                    <img class="w-full h-full object-cover" src={item.image} alt={item.title} loading="lazy" />
                  </figure>
                  <span class="solution-box-number">{item.slug.replace('giai-phap-', '0')}</span>
                  <h3 class="solution-box-title">{item.title}</h3>
                  <p class="solution-box-desc">{item.desc}</p>
                  <span class="solution-box-link">Xem chi tiết</span>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-14 md:py-16">
      <div class="max-w-container-max-width mx-auto px-6 md:px-8">
        <div class="solution-cta-banner bg-[#f2c300] px-6 py-10 md:px-10 text-center">
          <h2 class="text-2xl md:text-3xl font-bold text-black mb-3">Sẵn sàng nâng tầm hình ảnh doanh nghiệp?</h2>
          <p class="text-black/75 mb-6">
            Giải pháp đồng phục văn phòng được thiết kế để đồng nhất thương hiệu và nâng trải nghiệm nhân sự.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/#tai-lieu" class="px-6 py-3 bg-black text-white text-sm font-semibold rounded-full">
              Nhận tư vấn ngay
            </a>
            <a href="/#tai-lieu" class="px-6 py-3 border border-black text-black text-sm font-semibold rounded-full">
              Tải hồ sơ năng lực
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
