---
import { timeline, timelineSection } from '../../data/gioi-thieu';

/** 2.3 Hành trình 23 năm — timeline trục giữa, nội dung so le trái/phải (theo mô tả khách hàng) */
---

<section class="bg-paper py-24 md:py-36">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <div class="max-w-3xl mb-16 md:mb-24" data-reveal>
      <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-brass-dark mb-5">{timelineSection.eyebrow}</p>
      <h2 class="font-display-lg text-3xl md:text-5xl font-bold text-ink-dark tracking-tight leading-[1.12]">
        {timelineSection.title}
      </h2>
    </div>

    <div class="relative max-w-5xl mx-auto" data-reveal>
      <!-- Trục dọc trung tâm -->
      <span
        class="absolute left-4 md:left-1/2 top-2 bottom-2 w-px bg-border-subtle md:-translate-x-1/2"
        aria-hidden="true"></span>

      <ol class="list-none m-0 p-0 space-y-14 md:space-y-0">
        {
          timeline.map((item, index) => {
            const isLeft = index % 2 === 0;
            return (
              <li class="relative pl-14 md:pl-0 md:grid md:grid-cols-2 md:gap-x-24 md:pb-20 last:md:pb-0">
                <!-- Mốc kim cương vàng trên trục -->
                <span
                  class="absolute left-4 md:left-1/2 top-2 w-3 h-3 rotate-45 bg-brass ring-[7px] ring-paper -translate-x-1/2"
                  aria-hidden="true"
                ></span>
                <div
                  class:list={[
                    'space-y-3',
                    isLeft ? 'md:col-start-1 md:text-right' : 'md:col-start-2 md:text-left',
                  ]}
                >
                  <span class="font-serif text-2xl md:text-[2rem] text-brass-dark block leading-tight">
                    {item.year}
                  </span>
                  <h3 class="text-lg md:text-xl font-bold text-ink-dark tracking-tight leading-snug">
                    {item.title}
                  </h3>
                  <p
                    class:list={[
                      'text-text-muted text-sm md:text-[15px] leading-[1.8] max-w-md',
                      isLeft && 'md:ml-auto',
                    ]}
                  >
                    {item.desc}
                  </p>
                </div>
              </li>
            );
          })
        }
      </ol>
    </div>
  </div>
</section>
