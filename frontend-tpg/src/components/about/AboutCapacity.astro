---
import SectionHeading from '../SectionHeading.astro';
import ZigzagBlock from '../ZigzagBlock.astro';
import { productionCapacity } from '../../data/gioi-thieu';

/** 2.5 Năng lực sản xuất + QC đa tầng */
---

<section class="bg-paper py-24 md:py-36" id="nang-luc">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <SectionHeading
      eyebrow="Năng lực sản xuất"
      title="Quy mô & kiểm soát chất lượng"
      desc={productionCapacity.intro}
      class="max-w-3xl mb-12 md:mb-16"
    />

    <!-- Stats strip -->
    <dl class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 border-y border-border-subtle mb-20 md:mb-28" data-reveal>
      {
        productionCapacity.stats.map((stat, index) => (
          <div
            class:list={[
              'flex flex-col py-6 md:py-8 pr-4',
              index > 0 && 'lg:border-l lg:border-border-subtle lg:pl-6',
            ]}
          >
            <dt class="order-2 text-[10px] uppercase tracking-[0.16em] text-text-muted font-semibold leading-snug">
              {stat.label}
            </dt>
            <dd class="order-1 font-serif text-xl md:text-2xl text-ink-dark mb-1.5 m-0">{stat.value}</dd>
          </div>
        ))
      }
    </dl>

    <!-- Zig-zag: xưởng + QC -->
    <div class="space-y-20 md:space-y-32">
      {
        productionCapacity.blocks.map((block, index) => (
          <ZigzagBlock {...block} flip={index % 2 === 1} headingTag="h3" />
        ))
      }
    </div>
  </div>
</section>
