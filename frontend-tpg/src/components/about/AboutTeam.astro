---
import SectionHeading from '../SectionHeading.astro';
import { teamDepartments } from '../../data/gioi-thieu';

/** 2.6 Đội ngũ nhân sự — 4 cột mở, không card */
---

<section class="bg-white py-24 md:py-36">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <SectionHeading eyebrow="Con người Tân Phạm Gia" title="Đội ngũ nhân sự chuyên môn" />
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-12 border-t border-border-subtle pt-12" data-reveal>
      {
        teamDepartments.map((dept) => (
          <div class="space-y-4">
            <span class="font-serif text-3xl text-brass-dark block">{dept.num}</span>
            <h3 class="font-bold text-ink-dark text-base md:text-lg tracking-tight leading-snug">{dept.title}</h3>
            <p class="text-text-muted text-sm leading-[1.75]">{dept.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
