---
import SectionHeading from '../SectionHeading.astro';
import IndexList from '../IndexList.astro';
import { missionVision, coreValues } from '../../data/gioi-thieu';

/** 2.4 Định vị thương hiệu — Sứ mệnh / Tầm nhìn + 5 giá trị cốt lõi */
---

<section class="bg-white py-24 md:py-36">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <div class="grid md:grid-cols-2 gap-12 md:gap-20 mb-20 md:mb-28" data-reveal>
      <div class="space-y-5">
        <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-brass-dark">Sứ mệnh</p>
        <p class="font-serif text-xl md:text-2xl leading-[1.6] text-ink-dark">{missionVision.mission}</p>
      </div>
      <div class="space-y-5 md:border-l md:border-border-subtle md:pl-16">
        <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-brass-dark">Tầm nhìn</p>
        <p class="font-serif text-xl md:text-2xl leading-[1.6] text-ink-dark">{missionVision.vision}</p>
      </div>
    </div>

    <SectionHeading title="5 giá trị cốt lõi" size="md" class="max-w-3xl mb-12 md:mb-16" />
    <IndexList items={coreValues} size="sm" />
  </div>
</section>
