---
import SectionHeading from '../SectionHeading.astro';
import type { GiaiPhap } from '../../data/giai-phap';

interface Props {
  solution: GiaiPhap;
}

const { solution } = Astro.props;

/** 02 — Giải pháp từ Tân Phạm Gia: ảnh sticky + danh sách đánh số với dòng kết quả → */
---

<section class="bg-paper py-24 md:py-36">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <SectionHeading eyebrow="02 — Giải pháp" title="Giải pháp từ Tân Phạm Gia" size="num" />

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start" data-reveal>
      <figure class="lg:col-span-5 m-0 overflow-hidden lg:sticky lg:top-28">
        <img
          src={solution.image}
          alt={solution.title}
          loading="lazy"
          class="w-full aspect-[4/5] object-cover"
        />
      </figure>

      <ol class="lg:col-span-7 list-none m-0 p-0">
        {
          solution.plans.map((plan, index) => (
            <li class="border-b border-border-subtle py-8 md:py-10 first:pt-0 last:border-0">
              <div class="flex gap-6 md:gap-8">
                <span class="font-serif text-2xl md:text-3xl text-brass-dark leading-none shrink-0">
                  {String(index + 1).padStart(2, '0')}
                </span>
                <div class="space-y-3">
                  <h3 class="text-xl md:text-2xl font-bold text-ink-dark tracking-tight leading-snug">
                    {plan.title}
                  </h3>
                  <p class="text-text-muted text-[15px] md:text-base leading-[1.75]">{plan.desc}</p>
                  <p class="text-[15px] font-semibold text-ink-dark leading-relaxed">
                    <span class="text-brass-dark mr-2" aria-hidden="true">→</span>{plan.outcome}
                  </p>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
