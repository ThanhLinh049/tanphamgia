---
import SectionHeading from '../SectionHeading.astro';
import type { GiaiPhap } from '../../data/giai-phap';

interface Props {
  solution: GiaiPhap;
}

const { solution } = Astro.props;

/** 01 — Vấn đề thường gặp: index-list giữ nguyên cấu trúc nguyên nhân → hệ quả của khách */
---

<section class="bg-white py-24 md:py-36">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <SectionHeading eyebrow="01 — Vấn đề" title={solution.problemsTitle} size="num" />

    <ol class="border-t border-border-subtle list-none m-0 p-0" data-reveal>
      {
        solution.problems.map((problem, index) => (
          <li class="group border-b border-border-subtle transition-colors duration-500 hover:bg-paper">
            <div class="grid md:grid-cols-12 gap-4 md:gap-8 py-9 md:py-12">
              <span class="md:col-span-1 font-serif text-2xl md:text-3xl text-brass-dark leading-none">
                {String(index + 1).padStart(2, '0')}
              </span>
              <div class="md:col-span-5 space-y-2.5 md:pr-6">
                <h3 class="text-xl md:text-2xl font-bold text-ink-dark tracking-tight leading-snug">
                  {problem.title}
                </h3>
                {problem.cause && (
                  <p class="font-serif italic text-[15px] text-text-muted leading-relaxed">{problem.cause}</p>
                )}
              </div>
              <ul class="md:col-span-6 list-none m-0 p-0 space-y-2.5 md:pt-1">
                {problem.consequences.map((consequence) => (
                  <li class="flex gap-3 text-[15px] text-text-muted leading-[1.7]">
                    <span class="text-brass-dark font-semibold shrink-0" aria-hidden="true">→</span>
                    {consequence}
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
