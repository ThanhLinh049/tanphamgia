---
import ArrowLink from '../ArrowLink.astro';
import { giaiPhapList } from '../../data/giai-phap';
import { solutions } from '../../data/site';

/** 4 chương giải pháp — zig-zag ảnh lớn / nội dung, khác nhịp với mục lục trang chủ */
const chapters = giaiPhapList.map((item) => ({
  ...item,
  bullets: solutions.find((s) => s.slug === item.slug)?.bullets ?? [],
}));
---

<section class="bg-white py-24 md:py-36">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8 space-y-24 md:space-y-36">
    {
      chapters.map((chapter, index) => (
        <article class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center" data-reveal>
          <a
            href={`/giai-phap/${chapter.slug}`}
            class:list={['block lg:col-span-6 overflow-hidden group', index % 2 === 1 && 'lg:order-2']}
          >
            <img
              src={chapter.image}
              alt={chapter.title}
              loading="lazy"
              class="w-full aspect-[4/3] object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.03]"
            />
          </a>
          <div class:list={['lg:col-span-6 space-y-6', index % 2 === 1 && 'lg:order-1 lg:pr-8', index % 2 === 0 && 'lg:pl-8']}>
            <span class="font-serif text-3xl md:text-4xl text-brass-dark block">{chapter.number}</span>
            <h2 class="font-display-lg text-2xl md:text-[2.5rem] md:leading-[1.15] font-bold text-ink-dark tracking-tight">
              {chapter.title}
            </h2>
            <p class="text-text-muted text-[15px] md:text-[17px] leading-[1.8]">{chapter.desc}</p>
            {chapter.bullets.length > 0 && (
              <ul class="list-none m-0 p-0 border-t border-border-subtle">
                {chapter.bullets.map((bullet) => (
                  <li class="py-3 border-b border-border-subtle text-sm font-semibold text-ink-dark flex gap-3">
                    <span class="text-brass-dark shrink-0" aria-hidden="true">—</span>
                    {bullet}
                  </li>
                ))}
              </ul>
            )}
            <ArrowLink href={`/giai-phap/${chapter.slug}`} class="pt-2">Xem chi tiết giải pháp</ArrowLink>
          </div>
        </article>
      ))
    }
  </div>
</section>
