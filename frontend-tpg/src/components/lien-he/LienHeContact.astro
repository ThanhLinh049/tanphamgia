---
import { contactInfo, responseCommitments, formOptions } from '../../data/lien-he';

const inputClass =
  'w-full bg-transparent border-b border-border-subtle focus:border-brass-dark px-0 py-3 text-[15px] text-ink-dark placeholder:text-text-muted/50 transition-colors outline-none';
const labelClass =
  'text-[10px] font-bold uppercase tracking-[0.2em] text-text-muted group-focus-within:text-brass-dark transition-colors';

/**
 * 7.2 + 7.3 + 7.5 — Thông tin liên hệ (trái) + form Bownow 9 trường (phải).
 * Form đặt trong khung trắng có viền + bóng đổ rất nhẹ để tách khỏi khối thông tin.
 * Form chờ gắn endpoint Bownow — markup đã đủ name từng trường.
 */
---

<section class="bg-paper py-24 md:py-36">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8 grid lg:grid-cols-12 gap-14 lg:gap-20 items-start">
    <!-- 7.3 Thông tin liên hệ + 7.5 cam kết -->
    <div class="lg:col-span-4 space-y-12" data-reveal>
      <div>
        <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-brass-dark mb-6">Thông tin liên hệ</p>
        <dl class="border-t border-border-subtle m-0">
          {
            contactInfo.map((item) => (
              <div class="py-5 border-b border-border-subtle">
                <dt class="text-[10px] uppercase tracking-[0.2em] text-text-muted font-bold mb-1.5">{item.label}</dt>
                <dd class="m-0 text-[15px] font-semibold text-ink-dark leading-relaxed">
                  {item.href ? (
                    <a href={item.href} class="text-ink-dark hover:text-brass-dark transition-colors no-underline">
                      {item.value}
                    </a>
                  ) : (
                    item.value
                  )}
                  {item.note && <span class="block text-xs text-text-muted font-normal mt-1">{item.note}</span>}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div>
        <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-brass-dark mb-6">Cam kết của chúng tôi</p>
        <ul class="list-none m-0 p-0 border-t border-border-subtle">
          {
            responseCommitments.map((commitment) => (
              <li class="py-4 border-b border-border-subtle text-sm font-semibold text-ink-dark flex gap-3">
                <span class="text-brass-dark shrink-0" aria-hidden="true">✓</span>
                {commitment}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- 7.2 Form liên hệ — khung trắng viền + bóng đổ rất nhẹ -->
    <div class="lg:col-span-7 lg:col-start-6" data-reveal>
      <div class="bg-white border border-border-subtle shadow-[0_30px_70px_-45px_rgba(17,20,23,0.35)] p-7 md:p-10 xl:p-12">
        <h2 class="font-display-lg text-2xl md:text-4xl font-bold text-ink-dark tracking-tight leading-[1.15] mb-10">
          Gửi yêu cầu tư vấn & báo giá
        </h2>
        <form class="space-y-9">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-9">
            <div class="group">
              <label class={labelClass}>Họ tên *</label>
              <input class={inputClass} placeholder="Nguyễn Văn A" type="text" name="ho-ten" required />
            </div>
            <div class="group">
              <label class={labelClass}>Chức vụ</label>
              <input class={inputClass} placeholder="Trưởng phòng Hành chính" type="text" name="chuc-vu" />
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-9">
            <div class="group">
              <label class={labelClass}>Tên công ty *</label>
              <input class={inputClass} placeholder="Công ty CP ABC" type="text" name="cong-ty" required />
            </div>
            <div class="group">
              <label class={labelClass}>SĐT / Zalo *</label>
              <input class={inputClass} placeholder="090x xxx xxx" type="tel" name="dien-thoai" required />
            </div>
          </div>
          <div class="group">
            <label class={labelClass}>Email</label>
            <input class={inputClass} placeholder="ban@congty.vn" type="email" name="email" />
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-9">
            <div class="group">
              <label class={labelClass}>Ngành nghề</label>
              <select class:list={[inputClass, 'appearance-none']} name="nganh-nghe">
                {formOptions.industries.map((option) => <option>{option}</option>)}
              </select>
            </div>
            <div class="group">
              <label class={labelClass}>Số lượng dự kiến</label>
              <select class:list={[inputClass, 'appearance-none']} name="so-luong">
                {formOptions.quantities.map((option) => <option>{option}</option>)}
              </select>
            </div>
            <div class="group">
              <label class={labelClass}>Thời điểm cần</label>
              <select class:list={[inputClass, 'appearance-none']} name="thoi-diem">
                {formOptions.timelines.map((option) => <option>{option}</option>)}
              </select>
            </div>
          </div>
          <div class="group">
            <label class={labelClass}>Yêu cầu cụ thể</label>
            <textarea
              class:list={[inputClass, 'resize-none']}
              rows="4"
              name="yeu-cau"
              placeholder="Mô tả nhu cầu đồng phục của doanh nghiệp: loại sản phẩm, số lượng, yêu cầu thiết kế…"
            ></textarea>
          </div>
          <button
            class="w-full md:w-auto bg-brass text-ink-dark px-10 py-4 text-xs font-bold uppercase tracking-[0.16em] transition-colors duration-300 hover:bg-ink-dark hover:text-white"
          >
            Gửi yêu cầu tư vấn
          </button>
          <p class="text-xs text-text-muted !mt-5">Chúng tôi cam kết bảo mật thông tin doanh nghiệp theo quy định.</p>
        </form>
      </div>
    </div>
  </div>
</section>
