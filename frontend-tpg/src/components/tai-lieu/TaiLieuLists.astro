---
import SectionHeading from '../SectionHeading.astro';
import { brandDocs, catalogues, guides } from '../../data/tai-lieu';

/**
 * 6.2 → 6.4 — Ba nhóm tài liệu. Nút "Tải về" cuộn xuống form đăng ký (#dang-ky)
 * theo đúng luồng tài liệu khách: bấm Tải về → điền form → nhận link qua email.
 */
const downloadLabel = 'Tải về';
---

<!-- 6.2 Tài liệu thương hiệu -->
<section class="bg-white py-24 md:py-32" id="tai-lieu-thuong-hieu">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <SectionHeading
      eyebrow="01 — Tài liệu thương hiệu"
      title="Hồ sơ năng lực & Proposal"
      size="num"
      class="max-w-3xl mb-12 md:mb-16"
    />
    <div class="border-t border-border-subtle" data-reveal>
      {
        brandDocs.map((doc, index) => (
          <a
            href="#dang-ky"
            class="group grid md:grid-cols-12 gap-3 md:gap-8 items-center py-8 md:py-10 border-b border-border-subtle no-underline"
          >
            <span class="md:col-span-1 font-serif text-2xl md:text-3xl text-brass-dark leading-none">
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3 class="md:col-span-6 text-xl md:text-2xl font-bold text-ink-dark tracking-tight transition-colors duration-300 group-hover:text-brass-dark">
              <span class="solution-index-title">{doc.title}</span>
            </h3>
            {doc.meta && (
              <p class="md:col-span-3 text-[11px] uppercase tracking-[0.18em] text-text-muted font-semibold">
                {doc.meta}
              </p>
            )}
            <span class="md:col-span-2 flex md:justify-end items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-ink-dark group-hover:text-brass-dark transition-colors duration-300">
              {downloadLabel}
              <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<!-- 6.3 Catalogue sản phẩm -->
<section class="bg-paper py-24 md:py-32" id="catalogue">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <SectionHeading
      eyebrow="02 — Catalogue sản phẩm"
      title="Catalogue đồng phục 2026"
      size="num"
      class="max-w-3xl mb-12 md:mb-16"
    />
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-border-subtle" data-reveal>
      {
        catalogues.map((doc, index) => (
          <a
            href="#dang-ky"
            class="group flex flex-col justify-between gap-10 p-7 md:p-9 border-b border-r border-border-subtle no-underline transition-colors duration-500 hover:bg-white"
          >
            <span class="font-serif text-2xl md:text-3xl text-brass-dark leading-none">
              {String(index + 1).padStart(2, '0')}
            </span>
            <span class="space-y-4">
              <h3 class="text-lg md:text-xl font-bold text-ink-dark tracking-tight leading-snug transition-colors duration-300 group-hover:text-brass-dark">
                {doc.title}
              </h3>
              <span class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-ink-dark group-hover:text-brass-dark transition-colors duration-300">
                {downloadLabel}
                <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">→</span>
              </span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<!-- 6.4 Tài liệu hữu ích -->
<section class="bg-white py-24 md:py-32" id="tai-lieu-huu-ich">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <SectionHeading
      eyebrow="03 — Tài liệu hữu ích"
      title="Kiến thức triển khai đồng phục"
      size="num"
      class="max-w-3xl mb-12 md:mb-16"
    />
    <div class="border-t border-border-subtle" data-reveal>
      {
        guides.map((doc, index) => (
          <a
            href="#dang-ky"
            class="group grid grid-cols-12 gap-3 md:gap-8 items-center py-6 md:py-8 border-b border-border-subtle no-underline"
          >
            <span class="col-span-2 md:col-span-1 font-serif text-lg md:text-2xl text-brass-dark leading-none">
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3 class="col-span-10 md:col-span-9 text-base md:text-xl font-bold text-ink-dark tracking-tight leading-snug transition-colors duration-300 group-hover:text-brass-dark">
              {doc.title}
            </h3>
            <span class="hidden md:flex md:col-span-2 justify-end items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-ink-dark group-hover:text-brass-dark transition-colors duration-300">
              {downloadLabel}
              <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
