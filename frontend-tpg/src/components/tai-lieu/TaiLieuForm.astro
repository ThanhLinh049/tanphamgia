---
import { formCommitments, formIndustries } from '../../data/tai-lieu';

/**
 * 6.5 — Form thu thập thông tin khi tải: trái = text + 4 cam kết, phải = form 5 trường.
 * Sau submit sẽ gửi link tài liệu qua email (chờ tích hợp backend/email service).
 */
---

<section class="bg-ink-dark text-white py-24 md:py-36" id="dang-ky">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8 grid lg:grid-cols-12 gap-14 lg:gap-20 items-start">
    <div class="lg:col-span-5 space-y-7" data-reveal>
      <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-brass">Đăng ký nhận tài liệu</p>
      <h2 class="font-display-lg text-3xl md:text-5xl font-bold leading-[1.12] tracking-tight">
        Nhận trọn bộ tài liệu qua email
      </h2>
      <p class="text-white/65 text-[15px] md:text-[17px] leading-[1.8] max-w-md">
        Điền thông tin bên cạnh — link tải toàn bộ tài liệu bạn chọn sẽ được gửi tới email ngay sau khi đăng ký.
      </p>
      <ul class="list-none m-0 p-0 border-t border-white/10 max-w-md">
        {
          formCommitments.map((commitment) => (
            <li class="py-4 border-b border-white/10 text-sm font-semibold text-white/85 flex gap-3">
              <span class="text-brass shrink-0" aria-hidden="true">✓</span>
              {commitment}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="lg:col-span-6 lg:col-start-7" data-reveal>
      <form class="space-y-9 pt-2">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-9">
          <div class="group">
            <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/50 group-focus-within:text-brass transition-colors">Họ và tên</label>
            <input
              class="w-full bg-transparent border-b border-white/25 focus:border-brass px-0 py-3 text-[15px] text-white placeholder:text-white/30 transition-colors outline-none"
              placeholder="Nguyễn Văn A"
              type="text"
              name="ho-ten"
              required
            />
          </div>
          <div class="group">
            <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/50 group-focus-within:text-brass transition-colors">Tên công ty</label>
            <input
              class="w-full bg-transparent border-b border-white/25 focus:border-brass px-0 py-3 text-[15px] text-white placeholder:text-white/30 transition-colors outline-none"
              placeholder="Công ty CP ABC"
              type="text"
              name="cong-ty"
              required
            />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-9">
          <div class="group">
            <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/50 group-focus-within:text-brass transition-colors">Email</label>
            <input
              class="w-full bg-transparent border-b border-white/25 focus:border-brass px-0 py-3 text-[15px] text-white placeholder:text-white/30 transition-colors outline-none"
              placeholder="ban@congty.vn"
              type="email"
              name="email"
              required
            />
          </div>
          <div class="group">
            <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/50 group-focus-within:text-brass transition-colors">Số điện thoại</label>
            <input
              class="w-full bg-transparent border-b border-white/25 focus:border-brass px-0 py-3 text-[15px] text-white placeholder:text-white/30 transition-colors outline-none"
              placeholder="090x xxx xxx"
              type="tel"
              name="dien-thoai"
              required
            />
          </div>
        </div>
        <div class="group">
          <label class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/50 group-focus-within:text-brass transition-colors">Ngành</label>
          <select
            class="w-full bg-transparent border-b border-white/25 focus:border-brass px-0 py-3 text-[15px] text-white transition-colors outline-none appearance-none [&>option]:text-ink-dark"
            name="nganh"
          >
            {formIndustries.map((industry) => <option>{industry}</option>)}
          </select>
        </div>
        <button
          class="w-full md:w-auto bg-brass text-ink-dark px-10 py-4 text-xs font-bold uppercase tracking-[0.16em] transition-colors duration-300 hover:bg-white"
        >
          Tải trọn bộ tài liệu mới nhất
        </button>
        <p class="text-xs text-white/40 !mt-5">Chúng tôi cam kết bảo mật thông tin doanh nghiệp theo quy định.</p>
      </form>
    </div>
  </div>
</section>
