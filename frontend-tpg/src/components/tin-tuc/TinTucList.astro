---
import type { BlogPost } from '../../data/site';

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;

/**
 * 5.2 Danh sách bài viết + phân trang responsive.
 * Render toàn bộ bài (tốt cho SEO), script chia trang phía client:
 * mobile 4 bài/trang, desktop (≥768px) 12 bài/trang. No-JS: hiện tất cả.
 */
---

<div data-tt-list>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-14" data-reveal>
    {
      posts.map((post) => (
        <article class="group" data-tt-item>
          <figure class="m-0 overflow-hidden mb-5">
            <img
              src={post.image}
              alt={post.alt}
              loading="lazy"
              class="w-full aspect-[16/10] object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.03]"
            />
          </figure>
          <div class="space-y-2.5">
            <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-brass-dark">{post.category}</p>
            <h2 class="text-lg md:text-xl font-bold text-ink-dark tracking-tight leading-snug">{post.title}</h2>
            <p class="text-text-muted text-sm leading-[1.7] line-clamp-2">{post.excerpt}</p>
          </div>
        </article>
      ))
    }
  </div>

  <nav
    data-tt-pager
    aria-label="Phân trang"
    class="hidden items-center justify-center gap-2 pt-16 md:pt-20"
  ></nav>
</div>

<script src="../../scripts/tin-tuc-pager.ts"></script>
