---
import { certificates } from '../../data/site';

/** Giấy khen & chứng nhận — dòng inline chia divider (Sitemap 1.7) */
---

<section class="bg-white border-y border-border-subtle/60 py-12 md:py-14" id="chung-nhan">
  <ul class="max-w-container-max-width mx-auto px-6 md:px-8 grid grid-cols-2 md:grid-cols-4 gap-y-8 list-none m-0 p-0">
    {
      certificates.map((cert, index) => (
        <li class:list={['pr-6', index > 0 && 'md:border-l md:border-border-subtle md:pl-8']}>
          <h3 class="font-bold text-sm md:text-base text-ink-dark mb-1">{cert.title}</h3>
          <p class="text-text-muted text-xs md:text-[13px] leading-relaxed">{cert.desc}</p>
        </li>
      ))
    }
  </ul>
</section>
