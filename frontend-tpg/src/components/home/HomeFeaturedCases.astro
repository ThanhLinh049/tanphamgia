---
import SectionHeading from '../SectionHeading.astro';
import ArrowLink from '../ArrowLink.astro';
import { homeFeaturedCases } from '../../data/site';

const { featured, secondary, quote, contact, allProjectsHref } = homeFeaturedCases;
---

<section class="py-24 md:py-36 text-white bg-ink-dark overflow-hidden" id="du-an">
  <div class="max-w-container-max-width w-full mx-auto px-6 md:px-8">
    <header class="pb-14 md:pb-20 flex flex-col md:flex-row justify-between items-start md:items-end gap-6" data-reveal>
      <SectionHeading title="Dự án tiêu biểu" eyebrow="Case studies" tone="dark" class="max-w-2xl" reveal={false} />
      <ArrowLink href={allProjectsHref} tone="white-muted" class="shrink-0">Tất cả dự án</ArrowLink>
    </header>

    <!-- Case nổi bật — bố cục editorial -->
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center border-t border-white/10 pt-14 md:pt-20" data-reveal>
      <div class="lg:col-span-5 space-y-6">
        {featured.tag && (
          <p class="text-[11px] font-bold uppercase tracking-[0.25em] text-brass">{featured.tag}</p>
        )}
        <h3 class="font-display-lg text-3xl md:text-[2.75rem] md:leading-[1.12] font-bold tracking-tight">
          {featured.name}
        </h3>
        {featured.desc && (
          <p class="text-white/65 text-[15px] md:text-base leading-[1.8] max-w-md">{featured.desc}</p>
        )}
        {featured.stats && (
          <dl class="grid grid-cols-2 gap-8 pt-6 border-t border-white/10 max-w-md">
            {featured.stats.map((stat) => (
              <div class="flex flex-col">
                <dt class="order-2 text-[10px] uppercase tracking-[0.2em] text-white/50 font-semibold">{stat.label}</dt>
                <dd class="order-1 font-serif text-3xl md:text-4xl text-brass mb-1.5 m-0">{stat.value}</dd>
              </div>
            ))}
          </dl>
        )}
        <ArrowLink href={featured.href} tone="white" class="pt-2">Tìm hiểu chi tiết</ArrowLink>
      </div>
      <div class="lg:col-span-7">
        <a href={featured.href} class="block overflow-hidden group">
          <img
            src={featured.image}
            alt={featured.alt}
            class="w-full aspect-[16/10] object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.03]"
            loading="lazy"
          />
        </a>
      </div>
    </div>

    <!-- 2 case phụ + quote -->
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 pt-14 md:pt-20 mt-14 md:mt-20 border-t border-white/10">
      <blockquote class="lg:col-span-5 m-0 flex flex-col justify-center" data-reveal>
        <p class="font-serif italic text-lg md:text-2xl text-white/85 leading-[1.6]">"{quote.text}"</p>
        <footer class="text-[11px] uppercase tracking-[0.2em] text-white/45 mt-6 font-bold">— {quote.author}</footer>
      </blockquote>

      <div class="lg:col-span-7 grid sm:grid-cols-2 gap-8 lg:gap-10" role="list" data-reveal>
        {
          secondary.map((project) => (
            <a href={project.href} class="group block no-underline text-white" role="listitem">
              <span class="block overflow-hidden mb-5">
                <img
                  src={project.image}
                  alt={project.alt}
                  class="w-full aspect-[4/3] object-cover transition-transform duration-[1.2s] ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.03]"
                  loading="lazy"
                />
              </span>
              <span class="block space-y-1.5">
                <h4 class="font-bold text-lg tracking-tight transition-colors duration-300 group-hover:text-brass">
                  {project.name}
                </h4>
                {project.statHighlight && (
                  <p class="text-sm text-white/55">
                    <span class="font-serif text-xl text-white/90">{project.statHighlight.value}</span>{' '}
                    {project.statHighlight.suffix}
                  </p>
                )}
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <!-- Liên hệ trực tiếp — hàng đơn giản, không card -->
    <div class="mt-16 md:mt-24 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-start md:items-center gap-5">
      <p class="text-sm text-white/55">Cần giải pháp thiết kế riêng cho thương hiệu của bạn?</p>
      <p class="flex flex-wrap items-center gap-x-8 gap-y-2 text-sm">
        <a class="text-white/85 font-semibold hover:text-brass transition-colors no-underline" href={`mailto:${contact.email}`}>
          {contact.email}
        </a>
        <a class="text-white/85 font-semibold hover:text-brass transition-colors no-underline" href={contact.phoneHref}>
          {contact.phone}
        </a>
        <ArrowLink href={contact.ctaHref} tone="brass">{contact.ctaLabel}</ArrowLink>
      </p>
    </div>
  </div>
</section>
