---
import SectionHeading from '../SectionHeading.astro';
import ClientLogo from '../ClientLogo.astro';
import { clientLogos } from '../../data/site';

/**
 * Thương hiệu đồng hành — logo wall grayscale (Sitemap 1.6).
 * Gộp trọn cả slider mobile + lưới desktop trong 1 file (không tách component con).
 */
const LOGOS_PER_PAGE = 9;
const SLIDER_SETS = 3;

const basePages = [
  clientLogos.slice(0, LOGOS_PER_PAGE),
  clientLogos.slice(LOGOS_PER_PAGE),
].filter((page) => page.length > 0);

const sliderPages = Array.from({ length: SLIDER_SETS }, () => basePages).flat();
const pagesPerSet = basePages.length;
---

<section class="bg-paper py-24 md:py-32 border-y border-border-subtle/60" id="doi-tac">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8 grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
    <SectionHeading
      eyebrow="Khách hàng tin cậy"
      title="500+ doanh nghiệp đồng hành"
      desc="Niềm tin được tạo dựng bằng chất lượng nhất quán, sự chỉn chu trong từng sản phẩm và tinh thần đồng hành lâu dài."
      size="md"
      class="lg:col-span-4"
    />

    <div class="lg:col-span-8" data-reveal>
      <!-- Mobile: 3 hàng/trang, vuốt vòng lặp vô hạn -->
      <div class="home-clients-slider-wrap md:hidden" data-clients-slider>
        <div class="home-clients-slider" role="list" aria-label="Thương hiệu đồng hành">
          {
            sliderPages.map((page, pageIndex) => {
              const setIndex = Math.floor(pageIndex / pagesPerSet);
              const isClone = setIndex !== 1;

              return (
                <div
                  class="home-clients-page"
                  role="listitem"
                  aria-hidden={isClone ? 'true' : undefined}
                >
                  {page.map((client) => (
                    <ClientLogo name={client.name} logo={client.logo} />
                  ))}
                </div>
              );
            })
          }
        </div>
        {basePages.length > 1 && (
          <p class="home-clients-slider-hint">Vuốt ngang để xem thêm thương hiệu</p>
        )}
      </div>

      <!-- Desktop: lưới thoáng, logo grayscale -->
      <div class="hidden md:grid grid-cols-4 lg:grid-cols-5 gap-x-8 gap-y-7">
        {clientLogos.map((client) => <ClientLogo name={client.name} logo={client.logo} />)}
      </div>
    </div>
  </div>
</section>

<script src="../../scripts/home-clients-slider.ts"></script>
