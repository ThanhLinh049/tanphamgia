---
import { mainNavigation } from '../data/site';

/**
 * Header toàn site (logo + nav + nút liên hệ) — 1 file duy nhất, nằm trong BaseLayout.
 * Tự chứa trọn: markup + style + script cuộn (không tách file nhỏ).
 * Link luôn là trang thật; trang đang xem tự nhận diện từ URL (kể cả trang con).
 */
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) =>
  href !== '/' && (pathname === href || pathname.startsWith(`${href}/`));
---

<nav
  id="site-nav"
  class="fixed top-0 w-full z-50 border-b transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] bg-transparent border-transparent text-white"
>
  <div class="flex justify-between items-center px-6 md:px-8 max-w-container-max-width mx-auto">
    <a class="flex items-center group" href="/" aria-label="Tân Phạm Gia — Trang chủ">
      <img
        src="/images/logos/logo-tan-pham-gia.png"
        alt="Tân Phạm Gia"
        width="585"
        height="108"
        class="nav-logo h-7 md:h-8 w-auto transition-[filter] duration-300"
      />
    </a>
    <div class="hidden lg:flex gap-9 items-center">
      {
        mainNavigation.map((item) => (
          <a
            class:list={[
              'nav-link text-[11px] font-semibold uppercase tracking-[0.18em] transition-colors duration-300 text-white/85 hover:text-brass',
              isActive(item.href) && 'nav-link-active text-brass',
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/tai-lieu"
        class="bg-brass text-ink-dark px-5 py-2.5 text-[11px] font-bold uppercase tracking-[0.14em] transition-colors duration-300 hover:bg-ink-dark hover:text-white"
      >
        Nhận Báo Giá
      </a>
    </div>

    <!-- Nút menu mobile -->
    <button
      id="nav-toggle"
      class="nav-toggle lg:hidden inline-flex flex-col justify-center items-center w-9 h-9 -mr-2 text-white"
      aria-label="Mở menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <span class="nav-toggle-bar block w-6 h-[2px] bg-current transition-all duration-300"></span>
      <span class="nav-toggle-bar block w-6 h-[2px] bg-current mt-[5px] transition-all duration-300"></span>
      <span class="nav-toggle-bar block w-6 h-[2px] bg-current mt-[5px] transition-all duration-300"></span>
    </button>
  </div>

  <!-- Panel menu mobile -->
  <div
    id="nav-mobile"
    class="lg:hidden hidden bg-white border-t border-border-subtle"
  >
    <div class="px-6 py-4 flex flex-col">
      {
        mainNavigation.map((item) => (
          <a
            class:list={[
              'py-3.5 border-b border-border-subtle text-[13px] font-semibold uppercase tracking-[0.16em] no-underline transition-colors duration-200',
              isActive(item.href) ? 'text-brass-dark' : 'text-ink-dark hover:text-brass-dark',
            ]}
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/tai-lieu"
        class="mt-5 bg-brass text-ink-dark text-center px-5 py-3.5 text-[12px] font-bold uppercase tracking-[0.14em] transition-colors duration-300 hover:bg-ink-dark hover:text-white no-underline"
      >
        Nhận Báo Giá
      </a>
    </div>
  </div>
</nav>

<style is:global>
  /* —— Header: trong suốt trên hero → trắng mờ khi cuộn —— */
  #site-nav {
    transition: all 500ms cubic-bezier(0.16, 1, 0.3, 1);
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
  }

  #site-nav.nav-scrolled {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-color: rgba(220, 229, 226, 0.5);
    padding-top: 1.1rem;
    padding-bottom: 1.1rem;
  }

  #site-nav.nav-scrolled .nav-link {
    color: #111417;
  }

  #site-nav.nav-scrolled .nav-link:hover {
    color: #d9a713;
  }

  #site-nav.nav-scrolled .nav-link-active {
    color: #d9a713;
  }

  /* Logo: trắng khi header trong suốt trên nền tối → về màu gốc khi cuộn nền trắng */
  .nav-logo {
    filter: brightness(0) invert(1);
  }

  #site-nav.nav-scrolled .nav-logo,
  #site-nav.nav-open .nav-logo {
    filter: none;
  }

  /* Nút menu mobile: theo màu nav (trắng trên nền tối → đen khi cuộn/mở) */
  #site-nav.nav-scrolled .nav-toggle {
    color: #111417;
  }

  /* Khi mở menu: nav luôn nền trắng + icon thành dấu X */
  #site-nav.nav-open {
    background: #ffffff;
    border-color: rgba(220, 229, 226, 0.5);
  }

  #site-nav.nav-open .nav-toggle {
    color: #111417;
  }

  #site-nav.nav-open .nav-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  #site-nav.nav-open .nav-toggle-bar:nth-child(2) {
    opacity: 0;
  }

  #site-nav.nav-open .nav-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  // Cuộn mượt cho anchor nội trang
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener('click', (e) => {
      const href = anchor.getAttribute('href');
      if (!href || href === '#') return;
      e.preventDefault();
      const target = document.querySelector(href);
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    });
  });

  const nav = document.getElementById('site-nav');
  const heroImage = document.getElementById('hero-image');
  const navSolid = nav?.dataset.navSolid === 'true';

  /** Đồng bộ trạng thái nav theo vị trí scroll hiện tại */
  function updateNav() {
    const scrolled = window.pageYOffset;
    if (nav) nav.classList.toggle('nav-scrolled', navSolid || scrolled > 60);
    if (heroImage) heroImage.style.transform = `translateY(${scrolled * 0.25}px) scale(1.05)`;
  }

  if (nav && navSolid) {
    nav.classList.add('nav-scrolled');
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  // Khôi phục đúng màu khi reload/back-forward giữ vị trí scroll
  window.addEventListener('pageshow', updateNav);
  window.addEventListener('load', updateNav);
  updateNav();

  // —— Menu mobile: overlay tối toàn màn hình ——
  const toggle = document.getElementById('nav-toggle');
  const mobilePanel = document.getElementById('nav-mobile');

  function setMenu(open: boolean) {
    if (!nav || !toggle || !mobilePanel) return;
    nav.classList.toggle('nav-open', open);
    mobilePanel.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Đóng menu' : 'Mở menu');
  }

  toggle?.addEventListener('click', () => {
    setMenu(mobilePanel?.classList.contains('hidden') ?? true);
  });

  // Đóng menu khi chuyển sang desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024) setMenu(false);
  });
</script>
