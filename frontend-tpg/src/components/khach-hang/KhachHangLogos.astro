---
import SectionHeading from '../SectionHeading.astro';
import ClientLogo from '../ClientLogo.astro';
import { clientLogos } from '../../data/site';

/** 4.3 Logo khách hàng tiêu biểu — lưới grayscale toàn chiều rộng */
---

<section class="bg-white py-24 md:py-32 border-b border-border-subtle/60">
  <div class="max-w-container-max-width mx-auto px-6 md:px-8">
    <SectionHeading
      eyebrow="Thương hiệu tin cậy"
      title="Tân Phạm Gia được tin tưởng lựa chọn bởi"
      size="md"
      class="max-w-3xl mb-12 md:mb-16"
    />
    <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-x-8 gap-y-8" data-reveal>
      {clientLogos.map((client) => <ClientLogo name={client.name} logo={client.logo} />)}
    </div>
  </div>
</section>
