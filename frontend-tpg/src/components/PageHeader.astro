---
/**
 * Header trang dùng chung toàn site — gộp từ 7 header trang trước đây
 * (About/SolutionsIndex/Solution/KhachHang/TinTuc/TaiLieu/LienHe Header).
 * Nền tối + ảnh mờ + eyebrow + h1 + mô tả; nội dung nhận từ src/data.
 */
interface Props {
  eyebrow: string;
  title: string;
  desc: string;
  image: string;
  /** Eyebrow kiểu chữ serif lớn — vd "Giải pháp 01" ở trang chi tiết giải pháp */
  eyebrowSerif?: boolean;
  /** Mô tả dạng trích dẫn serif nghiêng — vd quote thương hiệu ở /giai-phap */
  descQuote?: boolean;
  /** Dải "đối tượng áp dụng" dưới header — chỉ trang chi tiết giải pháp */
  audiences?: string[];
}

const { eyebrow, title, desc, image, eyebrowSerif = false, descQuote = false, audiences } = Astro.props;

const hasAudiences = audiences && audiences.length > 0;
---

<header class="relative bg-ink-dark text-white overflow-hidden">
  <div class="absolute inset-0 opacity-20">
    <img alt="" class="w-full h-full object-cover" src={image} />
    <div class="absolute inset-0 bg-gradient-to-t from-ink-dark via-ink-dark/60 to-ink-dark/30"></div>
  </div>
  <div
    class:list={[
      'relative z-10 flex flex-col justify-end min-h-[440px] md:min-h-[540px] max-w-container-max-width mx-auto px-6 md:px-8 pt-36 md:pt-44',
      hasAudiences ? 'pb-12 md:pb-16' : 'pb-16 md:pb-24',
    ]}
  >
    {
      eyebrowSerif ? (
        <p class="font-serif text-2xl md:text-3xl text-brass mb-4">{eyebrow}</p>
      ) : (
        <p class="text-[11px] font-bold uppercase tracking-[0.3em] text-brass mb-5">{eyebrow}</p>
      )
    }
    <h1
      class:list={[
        'font-display-lg font-bold leading-[1.06] tracking-[-0.02em] max-w-4xl mb-6',
        hasAudiences
          ? 'text-[clamp(2.25rem,5.5vw,4.25rem)]'
          : 'text-[clamp(2.5rem,6vw,4.5rem)]',
      ]}
    >
      {title}
    </h1>
    {
      descQuote ? (
        <p class="font-serif italic text-white/70 text-lg md:text-xl max-w-2xl leading-relaxed">"{desc}"</p>
      ) : (
        <p class="text-white/70 text-base md:text-lg max-w-2xl leading-relaxed">{desc}</p>
      )
    }
  </div>

  {
    hasAudiences && (
      <div class="relative z-10 border-t border-white/15 bg-ink-dark/40 backdrop-blur-sm">
        <ul class="max-w-container-max-width mx-auto px-6 md:px-8 grid grid-cols-2 md:flex md:flex-row md:flex-wrap list-none m-0 p-0">
          {audiences.map((audience, index) => {
            const isRightCol = index % 2 === 1;
            const isLastRowMobile = index >= audiences.length - (audiences.length % 2 || 2);
            return (
              <li
                class:list={[
                  'py-3 md:py-5 pr-5 md:pr-6 text-[12px] md:text-[13px] font-semibold uppercase tracking-[0.14em] text-white/75',
                  isRightCol && 'pl-5 border-l border-white/10',
                  !isLastRowMobile && 'border-b border-white/10 md:border-b-0',
                  index > 0 && 'md:border-l md:border-white/10 md:pl-6',
                ]}
              >
                {audience}
              </li>
            );
          })}
        </ul>
      </div>
    )
  }
</header>
