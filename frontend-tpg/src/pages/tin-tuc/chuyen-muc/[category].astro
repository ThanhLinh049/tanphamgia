---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import TinTucFilter from '../../../components/tin-tuc/TinTucFilter.astro';
import TinTucList from '../../../components/tin-tuc/TinTucList.astro';
import { tinTucSeo, tinTucHeader, getCategories, getPostsByCategory } from '../../../data/tin-tuc';

export const getStaticPaths = (() => {
  return getCategories().map((category) => ({
    params: { category: category.slug },
    props: { categoryName: category.name },
  }));
}) satisfies GetStaticPaths;

interface Props {
  categoryName: string;
}

const { category } = Astro.params;
const { categoryName } = Astro.props;
const posts = getPostsByCategory(category!);
const pageTitle = `${categoryName} | Tin tức & Kiến thức đồng phục doanh nghiệp`;
---

<BaseLayout title={pageTitle} description={tinTucSeo.description}>
  <PageHeader {...tinTucHeader} />

  <section class="bg-paper py-24 md:py-32">
    <div class="max-w-container-max-width mx-auto px-6 md:px-8">
      <TinTucFilter activeSlug={category} />
      <TinTucList posts={posts} />
    </div>
  </section>
</BaseLayout>
