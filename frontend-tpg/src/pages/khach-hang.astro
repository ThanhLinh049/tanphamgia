---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import KhachHangLogos from '../components/khach-hang/KhachHangLogos.astro';
import KhachHangCases from '../components/khach-hang/KhachHangCases.astro';
import Testimonials from '../components/Testimonials.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { khachHangSeo, khachHangHeader } from '../data/khach-hang';
---

<BaseLayout title={khachHangSeo.title} description={khachHangSeo.description}>
  <PageHeader {...khachHangHeader} />
  <KhachHangLogos />
  <KhachHangCases />
  <Testimonials />
  <CtaBanner />
</BaseLayout>

